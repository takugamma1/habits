{%- liquid
  assign col_day     = section.settings.collection_day
  assign col_night   = section.settings.collection_night
  assign col_fit     = section.settings.collection_fit
  assign col_drinks  = section.settings.collection_drinks
  assign col_addons  = section.settings.collection_addons

  assign col_upsell   = section.settings.upsell_collection
  assign col_downsell = section.settings.downsell_collection
-%}

{%- comment -%} ═══════════════════════════════════
  LOADING OVERLAY (pulsing logo)
═══════════════════════════════════ {%- endcomment -%}
<div class="mp-loader" id="mp-loader" aria-hidden="true">
  <div class="mp-loader__inner">
    {% if section.settings.loading_logo %}
      {{ section.settings.loading_logo | image_url: width: 200 | image_tag: class: 'mp-loader__logo' }}
    {% else %}
      {% if settings.logo %}
        {{ settings.logo | image_url: width: 200 | image_tag: class: 'mp-loader__logo' }}
      {% endif %}
    {% endif %}
  </div>
</div>

{%- comment -%} ═══════════════════════════════════
  FLOATING CATEGORY NAV (bubble)
═══════════════════════════════════ {%- endcomment -%}
<div
  class="mp-nav-wrap"
  id="mp-nav-wrap"
  style="
    --mp-nav-bg: {{ section.settings.nav_bg | default: '#024b40' }};
    --mp-nav-text: {{ section.settings.nav_text_color | default: '#ffffff' }};
    --mp-badge-active: {{ section.settings.badge_active_color | default: '#ffffff' }};
    --mp-fit-icon-size: {{ section.settings.fit_menu_icon_size | default: 24 }}px;
  "
>
  <nav class="mp-nav" id="mp-nav">
    {%- comment -%} Logo → home {%- endcomment -%}
    <a href="/" class="mp-nav__logo" aria-label="{{ shop.name }}">
      {%- if settings.logo -%}
        {{ settings.logo | image_url: width: 160 | image_tag: loading: 'lazy', class: 'mp-nav__logo-img' }}
      {%- else -%}
        <span class="mp-nav__logo-text">{{ shop.name }}</span>
      {%- endif -%}
    </a>

    {%- comment -%} Category badges {%- endcomment -%}
    <div class="mp-nav__badges" id="mp-nav-badges">
      {% if col_day %}
        <button
          type="button"
          class="mp-badge mp-badge--time"
          data-collection="day"
          style="--mp-badge-bg: {{ section.settings.badge_color_day | default: '#2d5e45' }};"
        >
          {{ col_day.title | default: 'Day menu' }}
        </button>
      {% endif %}
      {% if col_night %}
        <button
          type="button"
          class="mp-badge mp-badge--time"
          data-collection="night"
          style="--mp-badge-bg: {{ section.settings.badge_color_night | default: '#2d5e45' }};"
        >
          {{ col_night.title | default: 'Night menu' }}
        </button>
      {% endif %}
      {% if col_fit %}
        <button
          type="button"
          class="mp-badge mp-badge--fit"
          data-collection="fit"
          style="--mp-badge-bg: {{ section.settings.badge_color_fit | default: '#2d5e45' }};"
        >
          {% if section.settings.fit_menu_icon %}
            {{ section.settings.fit_menu_icon | image_url: width: 80 | image_tag: class: 'mp-badge__icon mp-badge__icon--fit' }}
          {% else %}
            {{ col_fit.title | default: 'Fit menu' }}
          {% endif %}
        </button>
      {% endif %}
      {% if col_drinks %}
        <button
          type="button"
          class="mp-badge"
          data-collection="drinks"
          style="--mp-badge-bg: {{ section.settings.badge_color_drinks | default: '#2d5e45' }};"
        >
          {{ col_drinks.title | default: 'Drinks' }}
        </button>
      {% endif %}
      {% if col_addons %}
        <button
          type="button"
          class="mp-badge"
          data-collection="addons"
          style="--mp-badge-bg: {{ section.settings.badge_color_addons | default: '#2d5e45' }};"
        >
          {{ col_addons.title | default: 'Add-ons' }}
        </button>
      {% endif %}
    </div>
  </nav>

  {%- comment -%} Desktop cart circle (sits next to bubble) {%- endcomment -%}
  <button
    type="button"
    class="mp-cart-btn"
    id="mp-cart-btn-desktop"
    aria-label="Cart"
    style="--mp-cart-btn-bg: {{ section.settings.cart_icon_bg | default: '#024b40' }}; --mp-cart-btn-color: {{ section.settings.cart_icon_color | default: '#ffffff' }};"
  >
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
      <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4zM3 6h18"/>
      <path d="M16 10a4 4 0 01-8 0"/>
    </svg>
    <span class="mp-cart-btn__count" id="mp-cart-count-desktop" data-count="0">0</span>
  </button>
</div>

{%- comment -%} Cart drawers & mobile sheet (rendered outside nav) {%- endcomment -%}
{% render 'menu-cart-drawer',
  cart_badge_bg: section.settings.cart_badge_bg,
  cart_cta_text: section.settings.cart_cta_text,
  cart_cta_color: section.settings.cart_cta_color
%}

{%- comment -%} ═══════════════════════════════════
  MAIN CONTENT AREA
═══════════════════════════════════ {%- endcomment -%}
<div
  class="mp-content"
  id="mp-content"
  style="
    --mp-page-bg: {{ section.settings.page_bg | default: '#f5f3ef' }};
    --mp-margin: {{ section.settings.section_margin | default: 12 }}px;
    --mp-radius: {{ section.settings.border_radius | default: 24 }}px;
    --mp-columns: {{ section.settings.card_columns_desktop | default: 4 }};
    --mp-card-gap: {{ section.settings.card_gap | default: 16 }}px;
  "
>
  {%- comment -%} Kitchen closed message {%- endcomment -%}
  <div class="mp-closed" id="mp-closed" style="display:none;">
    <div class="mp-closed__card">
      {% if section.settings.loading_logo %}
        {{ section.settings.loading_logo | image_url: width: 120 | image_tag: class: 'mp-closed__logo' }}
      {% elsif settings.logo %}
        {{ settings.logo | image_url: width: 120 | image_tag: class: 'mp-closed__logo' }}
      {% endif %}
      <h2 class="mp-closed__heading">Кухнята е затворена</h2>
      <p class="mp-closed__text">Отваряме отново в <strong id="mp-closed-time">10:00</strong></p>
    </div>
  </div>

  {%- comment -%} Collection grids {%- endcomment -%}
  {% if col_day and col_day.products.size > 0 %}
    <div class="mp-collection" data-collection="day" style="display:none;">
      <h2 class="mp-collection__title">{{ col_day.title }}</h2>
      <div class="mp-grid">
        {% for product in col_day.products %}
          {% render 'menu-product-card',
            product: product,
            collection_title: col_day.title,
            card_bg: section.settings.card_bg,
            card_radius: section.settings.card_radius,
            button_color: section.settings.card_button_color,
            button_text_color: section.settings.card_button_text_color
          %}
        {% endfor %}
      </div>
    </div>
  {% endif %}

  {% if col_night and col_night.products.size > 0 %}
    <div class="mp-collection" data-collection="night" style="display:none;">
      <h2 class="mp-collection__title">{{ col_night.title }}</h2>
      <div class="mp-grid">
        {% for product in col_night.products %}
          {% render 'menu-product-card',
            product: product,
            collection_title: col_night.title,
            card_bg: section.settings.card_bg,
            card_radius: section.settings.card_radius,
            button_color: section.settings.card_button_color,
            button_text_color: section.settings.card_button_text_color
          %}
        {% endfor %}
      </div>
    </div>
  {% endif %}

  {% if col_fit and col_fit.products.size > 0 %}
    <div class="mp-collection mp-collection--fit" data-collection="fit" style="display:none;">
      <h2 class="mp-collection__title">{{ col_fit.title }}</h2>
      <div class="mp-grid mp-grid--fit">
        {% for product in col_fit.products %}
          {% render 'menu-fit-card',
            product: product,
            card_bg: section.settings.card_bg,
            card_radius: section.settings.card_radius,
            button_color: section.settings.card_button_color,
            button_text_color: section.settings.card_button_text_color
          %}
        {% endfor %}
      </div>
    </div>
  {% endif %}

  {% if col_drinks and col_drinks.products.size > 0 %}
    <div class="mp-collection" data-collection="drinks" style="display:none;">
      <h2 class="mp-collection__title">{{ col_drinks.title }}</h2>
      <div class="mp-grid">
        {% for product in col_drinks.products %}
          {% render 'menu-product-card',
            product: product,
            collection_title: col_drinks.title,
            card_bg: section.settings.card_bg,
            card_radius: section.settings.card_radius,
            button_color: section.settings.card_button_color,
            button_text_color: section.settings.card_button_text_color
          %}
        {% endfor %}
      </div>
    </div>
  {% endif %}

  {% if col_addons and col_addons.products.size > 0 %}
    <div class="mp-collection" data-collection="addons" style="display:none;">
      <h2 class="mp-collection__title">{{ col_addons.title }}</h2>
      <div class="mp-grid">
        {% for product in col_addons.products %}
          {% render 'menu-product-card',
            product: product,
            collection_title: col_addons.title,
            card_bg: section.settings.card_bg,
            card_radius: section.settings.card_radius,
            button_color: section.settings.card_button_color,
            button_text_color: section.settings.card_button_text_color
          %}
        {% endfor %}
      </div>
    </div>
  {% endif %}
</div>

{%- comment -%} ═══════════════════════════════════
  UPSELL MODAL
═══════════════════════════════════ {%- endcomment -%}
{% render 'menu-upsell-modal',
  upsell_collection: col_upsell,
  downsell_collection: col_downsell,
  upsell_title: section.settings.upsell_title,
  downsell_title: section.settings.downsell_title,
  addon_grid_cols: section.settings.addon_grid_cols
%}

{%- comment -%} ═══════════════════════════════════
  STYLES
═══════════════════════════════════ {%- endcomment -%}
{% stylesheet %}

  /* ─── Hide default header & footer on menu page ─── */
  .menu-page-section ~ #header-group,
  .menu-page-section ~ footer,
  body:has(.menu-page-section) #header-group,
  body:has(.menu-page-section) footer {
    display: none !important;
  }

  body:has(.menu-page-section) {
    background: var(--mp-page-bg, #f5f3ef);
  }

  /* ─── Loading overlay ─── */
  .mp-loader {
    position: fixed;
    inset: 0;
    z-index: 999999;
    background: var(--mp-page-bg, #f5f3ef);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: opacity 0.4s ease;
  }

  .mp-loader.is-hidden {
    opacity: 0;
    pointer-events: none;
  }

  .mp-loader__logo {
    width: 80px;
    height: auto;
    animation: mp-pulse 1.4s ease-in-out infinite;
  }

  @keyframes mp-pulse {
    0%, 100% { transform: scale(1); opacity: 0.7; }
    50% { transform: scale(1.1); opacity: 1; }
  }

  /* ─── Floating nav wrapper (positions bubble + cart circle) ─── */
  .mp-nav-wrap {
    position: fixed;
    top: 16px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 9999;
    display: flex;
    align-items: center;
    gap: 10px;
    transition: transform 0.3s ease, top 0.3s ease;
  }

  /* ─── Nav bubble (pill shape) ─── */
  .mp-nav {
    display: flex;
    align-items: center;
    gap: 14px;
    background: var(--mp-nav-bg, #024b40);
    padding: 10px 22px;
    border-radius: 9999px;
    box-shadow: 0 4px 24px rgba(0,0,0,0.12);
    transition: box-shadow 0.3s ease;
  }

  .mp-nav__logo {
    flex-shrink: 0;
    display: flex;
    align-items: center;
  }

  .mp-nav__logo-img {
    height: 32px;
    width: auto;
    object-fit: contain;
  }

  .mp-nav__logo-text {
    color: var(--mp-nav-text);
    font-weight: 700;
    font-size: 0.9375rem;
    white-space: nowrap;
  }

  .mp-nav__badges {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 2px 0;
  }

  /* ─── Category badges ─── */
  .mp-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    padding: 7px 16px;
    background: var(--mp-badge-bg, #2d5e45);
    color: var(--mp-nav-text, #fff);
    border: 2px solid transparent;
    border-radius: 9999px;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.03em;
    white-space: nowrap;
    cursor: pointer;
    transition: all 0.25s ease;
    flex-shrink: 0;
    font-family: inherit;
    text-transform: uppercase;
  }

  .mp-badge:hover {
    opacity: 0.85;
  }

  .mp-badge.is-active {
    border-color: var(--mp-badge-active, #fff);
    box-shadow: 0 0 0 1px var(--mp-badge-active, #fff);
  }

  .mp-badge.is-hidden {
    display: none;
  }

  .mp-badge__icon {
    width: 18px;
    height: 18px;
    object-fit: contain;
    border-radius: 4px;
  }

  /* Fit badge: icon-only, controllable size */
  .mp-badge--fit {
    padding: 7px 14px;
  }

  .mp-badge__icon--fit {
    width: var(--mp-fit-icon-size, 24px);
    height: auto;
    object-fit: contain;
    border-radius: 0;
  }

  /* ─── Desktop cart circle button (next to bubble) ─── */
  .mp-cart-btn {
    position: relative;
    flex-shrink: 0;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: var(--mp-cart-btn-bg, #024b40);
    color: var(--mp-cart-btn-color, #fff);
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.2s ease;
    box-shadow: 0 4px 24px rgba(0,0,0,0.12);
  }

  .mp-cart-btn:hover { transform: scale(1.06); }

  .mp-cart-btn__count {
    position: absolute;
    top: -4px;
    right: -4px;
    min-width: 20px;
    height: 20px;
    padding: 0 5px;
    border-radius: 9999px;
    background: #dd5934;
    color: #fff;
    font-size: 0.6875rem;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .mp-cart-btn__count[data-count="0"] {
    transform: scale(0);
  }

  @keyframes mp-bounce {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.3); }
  }

  .mp-cart-btn__count.is-bouncing {
    animation: mp-bounce 0.4s ease;
  }

  /* ─── Desktop side drawer ─── */
  .mp-drawer-overlay {
    position: fixed;
    inset: 0;
    z-index: 99990;
    background: rgba(0,0,0,0.4);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
  }

  .mp-drawer-overlay.is-open {
    opacity: 1;
    pointer-events: auto;
  }

  .mp-drawer {
    position: fixed;
    top: 0;
    right: 0;
    bottom: 0;
    width: 400px;
    max-width: 90vw;
    z-index: 99991;
    background: #fff;
    transform: translateX(100%);
    transition: transform 0.35s cubic-bezier(0.16, 1, 0.3, 1);
    display: flex;
    flex-direction: column;
    border-radius: 24px 0 0 24px;
    box-shadow: -4px 0 30px rgba(0,0,0,0.08);
  }

  .mp-drawer.is-open {
    transform: translateX(0);
  }

  .mp-drawer__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 20px 24px;
    border-bottom: 1px solid #eee;
  }

  .mp-drawer__title {
    margin: 0;
    font-size: 1rem;
    font-weight: 700;
    display: flex;
    align-items: center;
  }

  .mp-drawer__count {
    font-weight: 400;
    color: #888;
    margin-left: 4px;
  }

  .mp-drawer__close {
    background: none;
    border: none;
    padding: 6px;
    cursor: pointer;
    color: #333;
    display: flex;
  }

  .mp-drawer__body {
    flex: 1;
    overflow-y: auto;
    padding: 16px 24px;
  }

  .mp-drawer__empty {
    text-align: center;
    padding: 40px 0;
    color: #888;
  }

  .mp-drawer__items {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .mp-drawer__footer {
    padding: 16px 24px 24px;
    border-top: 1px solid #eee;
  }

  .mp-drawer__subtotal {
    display: flex;
    justify-content: space-between;
    font-weight: 700;
    font-size: 1rem;
    margin-bottom: 16px;
  }

  .mp-drawer__cta {
    display: block;
    width: 100%;
    text-align: center;
    padding: 14px;
    background: var(--mp-cta-bg, #024b40);
    color: #fff;
    border-radius: 12px;
    font-weight: 700;
    font-size: 0.9375rem;
    text-decoration: none;
    transition: opacity 0.2s ease;
  }

  .mp-drawer__cta:hover { opacity: 0.9; }

  /* ─── Phone field (shared by drawer + sheet) ─── */
  .mp-phone-field {
    display: flex;
    flex-direction: column;
    gap: 4px;
    margin-bottom: 14px;
  }

  .mp-phone-field__title {
    margin: 0 0 6px;
    font-size: 0.8125rem;
    font-weight: 600;
    color: #1a1a1a;
    line-height: 1.35;
  }

  .mp-phone-field__label {
    font-size: 0.75rem;
    font-weight: 600;
    color: #333;
  }

  .mp-phone-field__input {
    width: 100%;
    padding: 12px 14px;
    font-size: 1rem;
    color: #1a1a1a;
    background: #fff;
    border: 1px solid #d9d9d4;
    border-radius: 12px;
    outline: none;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
    -webkit-appearance: none;
    appearance: none;
  }

  .mp-phone-field__input::placeholder {
    color: #9a9a94;
  }

  .mp-phone-field__input:focus {
    border-color: var(--mp-cta-bg, #024b40);
    box-shadow: 0 0 0 3px rgba(2, 75, 64, 0.12);
  }

  .mp-phone-field.is-invalid .mp-phone-field__input {
    border-color: #c0392b;
    box-shadow: 0 0 0 3px rgba(192, 57, 43, 0.12);
  }

  .mp-phone-field__hint {
    font-size: 0.6875rem;
    color: #6b6b63;
    line-height: 1.4;
  }

  .mp-phone-field__error {
    display: none;
    font-size: 0.75rem;
    color: #c0392b;
    margin-top: 2px;
  }

  .mp-phone-field.is-invalid .mp-phone-field__error {
    display: block;
  }

  .mp-drawer__cta.is-disabled,
  .mp-sheet__cta.is-disabled {
    opacity: 0.5;
    pointer-events: none;
    cursor: not-allowed;
  }

  /* ─── Mobile overrides ─── */
  @media screen and (max-width: 749px) {
    .mp-nav-wrap {
      top: 10px;
      left: 50%;
      width: calc(100% - 16px);
      max-width: none;
    }

    .mp-nav {
      gap: 8px;
      padding: 10px 14px;
      width: 100%;
      overflow: hidden;
    }

    .mp-nav__logo-img {
      height: 26px;
    }

    .mp-nav__badges {
      gap: 5px;
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
      flex: 1;
      min-width: 0;
    }

    .mp-nav__badges::-webkit-scrollbar {
      display: none;
    }

    .mp-badge {
      padding: 6px 10px;
      font-size: 0.625rem;
      letter-spacing: 0.02em;
    }

    .mp-badge--fit {
      padding: 6px 8px;
    }

    .mp-badge__icon--fit {
      width: calc(var(--mp-fit-icon-size, 24px) * 0.75);
    }

    .mp-cart-btn#mp-cart-btn-desktop { display: none; }
    .mp-drawer-overlay, .mp-drawer { display: none; }
  }

  /* ─── Mobile bottom badge ─── */
  .mp-mob-badge {
    display: none;
  }

  @media screen and (max-width: 749px) {

    .mp-mob-badge {
      position: fixed;
      bottom: 20px;
      left: 50%;
      transform: translateX(-50%);
      z-index: 9998;
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 12px 24px;
      background: var(--mp-badge-bg, #024b40);
      color: #fff;
      border-radius: 9999px;
      cursor: pointer;
      box-shadow: 0 4px 24px rgba(0,0,0,0.15);
      transition: transform 0.3s ease;
    }

    .mp-mob-badge:active {
      transform: translateX(-50%) scale(0.96);
    }

    .mp-mob-badge__count {
      font-weight: 700;
      font-size: 0.875rem;
      min-width: 20px;
      text-align: center;
    }

    .mp-mob-badge__arrow {
      opacity: 0.6;
    }

    @keyframes mp-badge-bounce {
      0%, 100% { transform: translateX(-50%) translateY(0); }
      50% { transform: translateX(-50%) translateY(-6px); }
    }

    .mp-mob-badge.is-bouncing {
      animation: mp-badge-bounce 0.4s ease;
    }
  }

  /* ─── Mobile bottom sheet ─── */
  .mp-sheet-overlay,
  .mp-sheet {
    display: none;
  }

  @media screen and (max-width: 749px) {
    .mp-sheet-overlay {
      display: block;
      position: fixed;
      inset: 0;
      z-index: 99990;
      background: rgba(0,0,0,0.4);
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.3s ease;
    }

    .mp-sheet-overlay.is-open {
      opacity: 1;
      pointer-events: auto;
    }

    .mp-sheet {
      position: fixed;
      bottom: 0;
      left: 0;
      right: 0;
      z-index: 99991;
      background: #fff;
      border-radius: 24px 24px 0 0;
      max-height: 55vh;
      transform: translateY(100%);
      transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
      display: flex;
      flex-direction: column;
      box-shadow: 0 -4px 30px rgba(0,0,0,0.1);
    }

    .mp-sheet.is-open {
      transform: translateY(0);
    }

    .mp-sheet__handle {
      display: flex;
      justify-content: center;
      padding: 12px 0 4px;
    }

    .mp-sheet__handle-bar {
      width: 36px;
      height: 4px;
      border-radius: 9999px;
      background: #ddd;
    }

    .mp-sheet__header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 8px 20px 12px;
    }

    .mp-sheet__title {
      margin: 0;
      font-size: 1rem;
      font-weight: 700;
    }

    .mp-sheet__close {
      background: none;
      border: none;
      padding: 6px;
      cursor: pointer;
      color: #333;
      display: flex;
    }

    .mp-sheet__body {
      flex: 1;
      overflow-y: auto;
      padding: 0 20px 12px;
    }

    .mp-sheet__empty {
      text-align: center;
      padding: 24px 0;
      color: #888;
    }

    .mp-sheet__items {
      display: flex;
      flex-direction: column;
      gap: 12px;
    }

    .mp-sheet__footer {
      padding: 12px 20px 24px;
      border-top: 1px solid #eee;
    }

    .mp-sheet__subtotal {
      display: flex;
      justify-content: space-between;
      font-weight: 700;
      font-size: 0.9375rem;
      margin-bottom: 12px;
    }

    .mp-sheet__cta {
      display: block;
      width: 100%;
      text-align: center;
      padding: 14px;
      background: var(--mp-cta-bg, #024b40);
      color: #fff;
      border-radius: 12px;
      font-weight: 700;
      font-size: 0.9375rem;
      text-decoration: none;
    }
  }

  /* ─── Content area ─── */
  .mp-content {
    padding-top: 88px;
    padding-inline: var(--mp-margin, 12px);
    padding-bottom: 100px;
    min-height: 100vh;
    background: var(--mp-page-bg, #f5f3ef);
  }

  .mp-collection {
    margin-bottom: 40px;
  }

  .mp-collection__title {
    font-size: clamp(1.25rem, 2.5vw, 1.75rem);
    font-weight: 800;
    color: #1a1a1a;
    margin: 0 0 20px;
  }

  /* ─── Product grid ─── */
  .mp-grid {
    display: grid;
    grid-template-columns: repeat(var(--mp-columns, 4), 1fr);
    gap: var(--mp-card-gap, 16px);
  }

  @media screen and (max-width: 749px) {
    .mp-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 12px;
    }
  }

  /* ─── Product card ─── */
  .mp-card {
    border-radius: var(--mp-card-radius, 16px);
    overflow: hidden;
    background: var(--mp-card-bg, #1a1a1a);
    transition: transform 0.25s ease;
    position: relative;
    cursor: pointer;
  }

  .mp-card:hover {
    transform: translateY(-2px);
  }

  .mp-card__media {
    position: relative;
    aspect-ratio: 4 / 3;
    overflow: hidden;
  }

  .mp-card__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }

  .mp-card:hover .mp-card__img {
    transform: scale(1.04);
  }

  .mp-card__placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #2a2a2a;
    color: #555;
  }

  .mp-card__add {
    position: absolute;
    top: 10px;
    right: 10px;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: var(--mp-card-btn, #fff);
    color: var(--mp-card-btn-text, #1a1a1a);
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 2px 8px rgba(0,0,0,0.15);
    transition: transform 0.2s ease;
    z-index: 2;
  }

  .mp-card__add:hover {
    transform: scale(1.12);
  }

  .mp-card__info {
    padding: 14px 14px 16px;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .mp-card__title {
    margin: 0;
    font-size: 0.9375rem;
    font-weight: 700;
    color: #fff;
    line-height: 1.3;
  }

  .mp-card__desc {
    margin: 0;
    font-size: 0.75rem;
    color: rgba(255,255,255,0.55);
    line-height: 1.4;
  }

  .mp-card__price {
    font-size: 1rem;
    font-weight: 800;
    color: #fff;
    margin-top: 4px;
  }

  @media screen and (max-width: 749px) {
    .mp-card__info {
      padding: 10px 10px 12px;
    }

    .mp-card__title {
      font-size: 0.8125rem;
    }

    .mp-card__desc {
      font-size: 0.6875rem;
    }

    .mp-card__price {
      font-size: 0.875rem;
    }

    .mp-card__add {
      width: 32px;
      height: 32px;
      top: 8px;
      right: 8px;
    }
  }

  /* ─── Fit menu cards ─── */
  .mp-grid--fit {
    grid-template-columns: repeat(var(--mp-columns, 4), 1fr);
  }

  @media screen and (min-width: 750px) {
    .mp-grid--fit {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media screen and (max-width: 749px) {
    .mp-grid--fit {
      grid-template-columns: repeat(1, 1fr);
    }
  }

  .mp-card--fit .mp-card__media--fit {
    aspect-ratio: 16 / 10;
  }

  .mp-card--fit .mp-card__info--fit {
    padding: 16px 18px 20px;
    gap: 6px;
  }

  .mp-card--fit .mp-card__title {
    font-size: 1.0625rem;
  }

  .mp-card--fit .mp-card__price {
    font-size: 1.0625rem;
    margin-bottom: 4px;
  }

  .mp-fit-macros {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
    margin-top: 4px;
  }

  .mp-fit-macro {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 6px 10px;
    border-radius: 10px;
    min-width: 62px;
    gap: 2px;
  }

  .mp-fit-macro--protein {
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(59, 130, 246, 0.5);
    color: #fff;
  }

  .mp-fit-macro--carbs {
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(245, 158, 11, 0.5);
    color: #fff;
  }

  .mp-fit-macro--fats {
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(239, 68, 68, 0.5);
    color: #fff;
  }

  .mp-fit-macro__val {
    font-size: 0.8125rem;
    font-weight: 800;
    line-height: 1;
  }

  .mp-fit-macro__label {
    font-size: 0.5625rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    opacity: 0.8;
    line-height: 1;
  }

  .mp-fit-calories {
    display: flex;
    align-items: center;
    gap: 6px;
    margin-top: 4px;
    font-size: 0.8125rem;
    font-weight: 700;
    color: rgba(255,255,255,0.75);
  }

  .mp-fit-calories svg {
    color: #f59e0b;
    flex-shrink: 0;
  }

  .mp-fit-ingredients {
    margin-top: 6px;
    font-size: 0.6875rem;
    line-height: 1.4;
    color: rgba(255,255,255,0.5);
  }

  .mp-fit-ingredients__label {
    font-weight: 700;
    color: rgba(255,255,255,0.65);
  }

  @media screen and (max-width: 749px) {
    .mp-card--fit .mp-card__info--fit {
      padding: 12px 14px 16px;
    }

    .mp-card--fit .mp-card__title {
      font-size: 0.9375rem;
    }

    .mp-fit-macro {
      padding: 5px 8px;
      min-width: 54px;
    }

    .mp-fit-macro__val {
      font-size: 0.75rem;
    }

    .mp-fit-macro__label {
      font-size: 0.5rem;
    }
  }

  /* ─── Kitchen closed ─── */
  .mp-closed__card {
    text-align: center;
    padding: 60px 24px;
  }

  .mp-closed__logo {
    width: 80px;
    height: auto;
    margin-bottom: 24px;
    opacity: 0.5;
  }

  .mp-closed__heading {
    margin: 0 0 8px;
    font-size: 1.5rem;
    font-weight: 800;
    color: #1a1a1a;
  }

  .mp-closed__text {
    margin: 0;
    font-size: 1rem;
    color: #666;
  }

  /* ─── Upsell modal ─── */
  .mp-upsell-overlay {
    position: fixed;
    inset: 0;
    z-index: 99992;
    background: rgba(0,0,0,0.5);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
  }

  .mp-upsell-overlay.is-open {
    opacity: 1;
    pointer-events: auto;
  }

  .mp-upsell {
    position: fixed;
    z-index: 99993;
    background: #fff;
    overflow: hidden;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease, transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    display: flex;
    flex-direction: column;
  }

  .mp-upsell.is-open {
    opacity: 1;
    pointer-events: auto;
  }

  /* Desktop: centered modal */
  @media screen and (min-width: 750px) {
    .mp-upsell {
      top: 50%;
      left: 50%;
      transform: translate(-50%, -48%);
      width: 420px;
      max-width: 92vw;
      max-height: 85vh;
      border-radius: 24px;
      box-shadow: 0 8px 40px rgba(0,0,0,0.15);
    }

    .mp-upsell.is-open {
      transform: translate(-50%, -50%);
    }
  }

  /* Mobile: bottom sheet */
  @media screen and (max-width: 749px) {
    .mp-upsell {
      bottom: 0;
      left: 0;
      right: 0;
      max-height: 80vh;
      border-radius: 24px 24px 0 0;
      transform: translateY(100%);
      box-shadow: 0 -4px 30px rgba(0,0,0,0.1);
    }

    .mp-upsell.is-open {
      transform: translateY(0);
    }

    .mp-upsell__preview-img {
      width: 44px;
      height: 44px;
    }
  }

  .mp-upsell__close {
    position: absolute;
    top: 16px;
    right: 16px;
    background: none;
    border: none;
    padding: 6px;
    cursor: pointer;
    color: #333;
    display: flex;
    z-index: 2;
  }

  /* ─── Selected product preview ─── */
  .mp-upsell__preview {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 16px 20px 0;
    flex-shrink: 0;
  }

  .mp-upsell__preview-img {
    width: 52px;
    height: 52px;
    border-radius: 10px;
    object-fit: cover;
    background: #f5f3ef;
    flex-shrink: 0;
  }

  .mp-upsell__preview-info {
    display: flex;
    flex-direction: column;
    gap: 2px;
    min-width: 0;
  }

  .mp-upsell__preview-name {
    font-size: 0.875rem;
    font-weight: 700;
    color: #1a1a1a;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .mp-upsell__preview-price {
    font-size: 0.8125rem;
    font-weight: 600;
    color: #024b40;
  }

  /* ─── Body (single page) ─── */
  .mp-upsell__body {
    padding: 16px 20px 0;
    flex: 1;
    min-height: 0;
    overflow-y: auto;
    -webkit-overflow-scrolling: touch;
  }

  .mp-upsell__title {
    margin: 0 0 12px;
    font-size: 1rem;
    font-weight: 800;
    color: #1a1a1a;
  }

  /* ─── Addon tile grid ─── */
  .mp-upsell__grid {
    display: grid;
    grid-template-columns: repeat(var(--mp-addon-cols, 3), 1fr);
    gap: 8px;
    margin-bottom: 0;
  }

  .mp-addon-tile {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    cursor: pointer;
    position: relative;
  }

  .mp-addon-tile__img-wrap {
    position: relative;
    width: 100%;
    aspect-ratio: 1 / 1;
    border-radius: 14px;
    overflow: hidden;
    border: 2px solid #eee;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
    background: #f9f9f9;
  }

  .mp-addon-tile:hover .mp-addon-tile__img-wrap {
    border-color: #ccc;
  }

  .mp-addon-tile.is-selected .mp-addon-tile__img-wrap {
    border-color: #024b40;
    box-shadow: 0 0 0 1px #024b40;
  }

  .mp-addon-tile__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .mp-addon-tile__placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #ccc;
  }

  .mp-addon-tile__check-icon {
    position: absolute;
    top: 6px;
    right: 6px;
    width: 24px;
    height: 24px;
    border-radius: 50%;
    background: #024b40;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transform: scale(0.5);
    transition: opacity 0.2s ease, transform 0.2s ease;
  }

  .mp-addon-tile.is-selected .mp-addon-tile__check-icon {
    opacity: 1;
    transform: scale(1);
  }

  .mp-addon-tile__name {
    font-size: 0.75rem;
    font-weight: 600;
    color: #1a1a1a;
    margin-top: 6px;
    line-height: 1.2;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .mp-addon-tile__price {
    font-size: 0.6875rem;
    color: #888;
    margin-top: 2px;
  }

  .mp-addon-tile__input {
    position: absolute;
    opacity: 0;
    pointer-events: none;
  }

  .mp-upsell__check {
    position: absolute;
    opacity: 0;
    pointer-events: none;
  }

  /* ─── Product detail popup (layered on top of upsell) ─── */
  .mp-product-popup-overlay {
    position: fixed;
    inset: 0;
    z-index: 99994;
    background: rgba(0,0,0,0.35);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.25s ease;
  }

  .mp-product-popup-overlay.is-open {
    opacity: 1;
    pointer-events: auto;
  }

  .mp-product-popup {
    position: fixed;
    z-index: 99995;
    background: #fff;
    overflow: hidden;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.25s ease, transform 0.35s cubic-bezier(0.16, 1, 0.3, 1);
    display: flex;
    flex-direction: column;
  }

  .mp-product-popup.is-open {
    opacity: 1;
    pointer-events: auto;
  }

  @media screen and (min-width: 750px) {
    .mp-product-popup {
      top: 50%;
      left: 50%;
      transform: translate(-50%, -46%);
      width: 420px;
      max-width: 90vw;
      max-height: 80vh;
      border-radius: 20px;
      box-shadow: 0 12px 48px rgba(0,0,0,0.2);
    }
    .mp-product-popup.is-open {
      transform: translate(-50%, -50%);
    }
  }

  @media screen and (max-width: 749px) {
    .mp-product-popup {
      bottom: 0;
      left: 0;
      right: 0;
      max-height: 88vh;
      border-radius: 20px 20px 0 0;
      transform: translateY(100%);
      box-shadow: 0 -4px 30px rgba(0,0,0,0.12);
    }
    .mp-product-popup.is-open {
      transform: translateY(0);
    }
  }

  .mp-product-popup__back {
    position: absolute;
    top: 14px;
    left: 14px;
    background: rgba(255,255,255,0.9);
    backdrop-filter: blur(8px);
    border: none;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 2;
    box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    transition: transform 0.15s ease;
  }

  .mp-product-popup__back:hover {
    transform: scale(1.08);
  }

  .mp-product-popup__body {
    overflow-y: auto;
    -webkit-overflow-scrolling: touch;
  }

  .mp-product-popup__img-wrap {
    width: 100%;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: #f5f3ef;
  }

  .mp-product-popup__img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .mp-product-popup__info {
    padding: 20px 24px 24px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .mp-product-popup__title {
    margin: 0;
    font-size: 1.25rem;
    font-weight: 800;
    color: #1a1a1a;
  }

  .mp-product-popup__price {
    font-size: 1rem;
    font-weight: 700;
    color: #024b40;
  }

  .mp-product-popup__desc {
    margin: 0;
    font-size: 0.875rem;
    color: #666;
    line-height: 1.5;
  }

  .mp-product-popup__add-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    width: 100%;
    padding: 14px;
    margin-top: 8px;
    border: none;
    border-radius: 14px;
    background: #024b40;
    color: #fff;
    font-weight: 700;
    font-size: 0.9375rem;
    cursor: pointer;
    transition: opacity 0.2s ease;
    font-family: inherit;
  }

  .mp-product-popup__add-btn:hover {
    opacity: 0.9;
  }

  .mp-upsell__actions {
    display: flex;
    gap: 10px;
    padding: 12px 20px 16px;
    flex-shrink: 0;
  }

  .mp-upsell__skip {
    flex: 1;
    padding: 12px;
    border: 1px solid #ddd;
    border-radius: 12px;
    background: #fff;
    color: #666;
    font-weight: 600;
    font-size: 0.875rem;
    cursor: pointer;
    transition: background 0.2s ease;
    font-family: inherit;
  }

  .mp-upsell__skip:hover { background: #f5f5f5; }

  .mp-upsell__next {
    flex: 1;
    padding: 12px;
    border: none;
    border-radius: 12px;
    background: #024b40;
    color: #fff;
    font-weight: 700;
    font-size: 0.875rem;
    cursor: pointer;
    transition: opacity 0.2s ease;
    font-family: inherit;
  }

  .mp-upsell__next:hover { opacity: 0.9; }

  /* dots removed — single page layout */

  .mp-upsell__empty {
    text-align: center;
    padding: 20px;
    color: #888;
  }

  /* ─── Cart item (shared layout for drawer/sheet) ─── */
  .mp-cart-item {
    display: flex;
    gap: 12px;
    align-items: center;
  }

  .mp-cart-item__img {
    width: 52px;
    height: 52px;
    border-radius: 10px;
    object-fit: cover;
    flex-shrink: 0;
  }

  .mp-cart-item__info {
    flex: 1;
    min-width: 0;
  }

  .mp-cart-item__name {
    font-size: 0.8125rem;
    font-weight: 600;
    color: #1a1a1a;
    margin: 0 0 2px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .mp-cart-item__price {
    font-size: 0.75rem;
    color: #888;
  }

  .mp-cart-item__qty {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-shrink: 0;
  }

  .mp-cart-item__qty-btn {
    width: 28px;
    height: 28px;
    border-radius: 8px;
    border: 1px solid #ddd;
    background: #fff;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1rem;
    color: #333;
    font-weight: 600;
    transition: background 0.15s ease;
    font-family: inherit;
  }

  .mp-cart-item__qty-btn:hover { background: #f5f5f5; }

  .mp-cart-item__qty-num {
    font-size: 0.875rem;
    font-weight: 700;
    min-width: 16px;
    text-align: center;
  }

{% endstylesheet %}

