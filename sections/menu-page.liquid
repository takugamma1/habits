<script>
(function () {
  'use strict';

  /* ─────────── Utility ─────────── */
  function getEETTime() {
    var now = new Date();
    var eet = new Intl.DateTimeFormat('en-US', {
      timeZone: 'Europe/Sofia',
      hour: 'numeric',
      minute: 'numeric',
      hour12: false
    }).format(now);
    var parts = eet.split(':');
    return parseFloat(parts[0]) + parseFloat(parts[1]) / 60;
  }

  function formatMoney(cents) {
    return (cents / 100).toFixed(2).replace('.', ',') + ' лв.';
  }

  function $(sel, ctx) { return (ctx || document).querySelector(sel); }
  function $$(sel, ctx) { return Array.from((ctx || document).querySelectorAll(sel)); }

  /* ─────────── State ─────────── */
  var state = {
    activeCollection: null,
    cart: null,
    pendingVariant: null,
    upsellOpen: false
  };

  /* ─────────── DOM refs ─────────── */
  var loader = $('#mp-loader');
  var nav = $('#mp-nav');
  var badges = $$('.mp-badge');
  var collections = $$('.mp-collection');
  var closedMsg = $('#mp-closed');

  // Desktop cart
  var cartBtnDesktop = $('#mp-cart-btn-desktop');
  var drawerOverlay = $('#mp-drawer-overlay');
  var drawer = $('#mp-drawer-desktop');
  var drawerClose = $('#mp-drawer-close');
  var drawerBody = $('#mp-drawer-body');
  var drawerItems = $('#mp-drawer-items');
  var drawerEmpty = $('#mp-drawer-empty');
  var drawerSubtotal = $('#mp-drawer-subtotal');
  var drawerCount = $('#mp-drawer-count');
  var cartCountDesktop = $('#mp-cart-count-desktop');

  // Mobile cart
  var mobBadge = $('#mp-mob-badge');
  var sheetOverlay = $('#mp-sheet-overlay');
  var sheet = $('#mp-sheet');
  var sheetClose = $('#mp-sheet-close');
  var sheetItems = $('#mp-sheet-items');
  var sheetEmpty = $('#mp-sheet-empty');
  var sheetSubtotal = $('#mp-sheet-subtotal');
  var sheetCount = $('#mp-sheet-count');
  var cartCountMobile = $('#mp-cart-count-mobile');

  // Upsell
  var upsellOverlay = $('#mp-upsell-overlay');
  var upsell = $('#mp-upsell');
  var upsellClose = $('#mp-upsell-close');

  /* ─────────── Time-based logic ─────────── */
  function initTimeLogic() {
    var t = getEETTime();
    var isDay = t >= 9.75 && t < 17.25;    // 9:45 - 17:15
    var isNight = t >= 16.75 && t < 22.25;  // 16:45 - 22:15
    var isClosed = !isDay && !isNight;

    // Show/hide time-based badges
    badges.forEach(function (b) {
      if (b.dataset.collection === 'day') {
        b.classList.toggle('is-hidden', !isDay);
      }
      if (b.dataset.collection === 'night') {
        b.classList.toggle('is-hidden', !isNight);
      }
    });

    // Show kitchen closed if no food menu is available
    if (isClosed) {
      closedMsg.style.display = '';
      // Find next opening time
      var nextTime = t >= 22.25 ? '10:00' : '10:00';
      var el = $('#mp-closed-time');
      if (el) el.textContent = nextTime;
    }

    // Auto-select the time-appropriate category
    if (isDay) {
      selectCollection('day');
    } else if (isNight) {
      selectCollection('night');
    } else {
      // During closed hours, show Fit or Drinks by default
      var firstAvail = badges.find(function (b) {
        return !b.classList.contains('is-hidden') && !b.classList.contains('mp-badge--time');
      });
      if (firstAvail) {
        selectCollection(firstAvail.dataset.collection);
      }
    }
  }

  /* ─────────── Collection switching ─────────── */
  function selectCollection(key) {
    state.activeCollection = key;

    // Update badges
    badges.forEach(function (b) {
      b.classList.toggle('is-active', b.dataset.collection === key);
    });

    // Show/hide collections
    collections.forEach(function (c) {
      c.style.display = c.dataset.collection === key ? '' : 'none';
    });
  }

  // Badge clicks
  badges.forEach(function (b) {
    b.addEventListener('click', function () {
      selectCollection(b.dataset.collection);
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
  });

  /* ─────────── Cart AJAX ─────────── */
  function fetchCart() {
    return fetch('/cart.js')
      .then(function (r) { return r.json(); })
      .then(function (cart) {
        state.cart = cart;
        renderCart(cart);
        return cart;
      });
  }

  function addToCart(items) {
    return fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ items: items })
    })
    .then(function (r) {
      if (!r.ok) {
        return r.json().then(function (err) {
          console.error('[Habits] Cart add failed:', err);
          throw new Error(err.description || err.message || 'Cart add failed');
        });
      }
      return r.json();
    })
    .then(function () { return fetchCart(); })
    .catch(function (err) {
      console.error('[Habits] addToCart error:', err);
      return fetchCart();
    });
  }

  function changeQuantity(key, qty) {
    return fetch('/cart/change.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ id: key, quantity: qty })
    })
    .then(function (r) { return r.json(); })
    .then(function () { return fetchCart(); });
  }

  /* ─────────── Render cart ─────────── */
  function renderCart(cart) {
    var count = cart.item_count;
    var total = formatMoney(cart.total_price);

    // Update all counts
    if (cartCountDesktop) {
      cartCountDesktop.textContent = count;
      cartCountDesktop.dataset.count = count;
    }
    if (cartCountMobile) {
      cartCountMobile.textContent = count;
      cartCountMobile.dataset.count = count;
    }
    if (drawerCount) drawerCount.textContent = '(' + count + ')';
    if (sheetCount) sheetCount.textContent = '(' + count + ')';
    if (drawerSubtotal) drawerSubtotal.textContent = total;
    if (sheetSubtotal) sheetSubtotal.textContent = total;

    // Build item HTML
    var html = '';
    cart.items.forEach(function (item) {
      html += '<div class="mp-cart-item" data-key="' + item.key + '">' +
        '<img class="mp-cart-item__img" src="' + (item.image ? item.image.replace(/(\.[^.]+)$/, '_100x100$1') : '') + '" alt="' + item.title + '" width="52" height="52">' +
        '<div class="mp-cart-item__info">' +
          '<p class="mp-cart-item__name">' + item.product_title + '</p>' +
          '<span class="mp-cart-item__price">' + formatMoney(item.final_line_price) + '</span>' +
        '</div>' +
        '<div class="mp-cart-item__qty">' +
          '<button type="button" class="mp-cart-item__qty-btn" data-action="minus" data-key="' + item.key + '">−</button>' +
          '<span class="mp-cart-item__qty-num">' + item.quantity + '</span>' +
          '<button type="button" class="mp-cart-item__qty-btn" data-action="plus" data-key="' + item.key + '">+</button>' +
        '</div>' +
      '</div>';
    });

    // Desktop drawer
    if (drawerItems) drawerItems.innerHTML = html;
    if (drawerEmpty) drawerEmpty.style.display = count === 0 ? '' : 'none';

    // Mobile sheet
    if (sheetItems) sheetItems.innerHTML = html;
    if (sheetEmpty) sheetEmpty.style.display = count === 0 ? '' : 'none';

    // Wire quantity buttons
    $$('.mp-cart-item__qty-btn').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var key = btn.dataset.key;
        var numEl = btn.parentElement.querySelector('.mp-cart-item__qty-num');
        var currentQty = parseInt(numEl.textContent, 10);
        var newQty = btn.dataset.action === 'plus' ? currentQty + 1 : currentQty - 1;
        changeQuantity(key, Math.max(0, newQty));
      });
    });
  }

  function bounceCartBadge() {
    if (cartCountDesktop) {
      cartCountDesktop.classList.add('is-bouncing');
      setTimeout(function () { cartCountDesktop.classList.remove('is-bouncing'); }, 400);
    }
    if (mobBadge) {
      mobBadge.classList.add('is-bouncing');
      setTimeout(function () { mobBadge.classList.remove('is-bouncing'); }, 400);
    }
  }

  /* ─────────── Desktop drawer ─────────── */
  function openDrawer() {
    if (drawer) drawer.classList.add('is-open');
    if (drawerOverlay) drawerOverlay.classList.add('is-open');
    document.body.style.overflow = 'hidden';
  }

  function closeDrawer() {
    if (drawer) drawer.classList.remove('is-open');
    if (drawerOverlay) drawerOverlay.classList.remove('is-open');
    document.body.style.overflow = '';
  }

  if (cartBtnDesktop) cartBtnDesktop.addEventListener('click', openDrawer);
  if (drawerClose) drawerClose.addEventListener('click', closeDrawer);
  if (drawerOverlay) drawerOverlay.addEventListener('click', closeDrawer);

  /* ─────────── Mobile sheet ─────────── */
  function openSheet() {
    if (sheet) sheet.classList.add('is-open');
    if (sheetOverlay) sheetOverlay.classList.add('is-open');
    if (mobBadge) mobBadge.style.display = 'none';
    document.body.style.overflow = 'hidden';
  }

  function closeSheet() {
    if (sheet) sheet.classList.remove('is-open');
    if (sheetOverlay) sheetOverlay.classList.remove('is-open');
    if (mobBadge) mobBadge.style.display = '';
    document.body.style.overflow = '';
  }

  if (mobBadge) mobBadge.addEventListener('click', openSheet);
  if (sheetClose) sheetClose.addEventListener('click', closeSheet);
  if (sheetOverlay) sheetOverlay.addEventListener('click', closeSheet);

  /* ─────────── Delivery phone (required for Wolt dispatch) ─────────── */
  var PHONE_REGEX = /^(\+359|0)[0-9]{9}$/;
  var PHONE_STORAGE_KEY = 'habits_delivery_phone';

  function normalizePhone(val) {
    var trimmed = (val || '').trim().replace(/\s+/g, '');
    if (trimmed.charAt(0) === '0') return '+359' + trimmed.substring(1);
    return trimmed;
  }

  function validatePhoneValue(val) {
    var trimmed = (val || '').trim();
    if (!trimmed) return { ok: false, message: 'Моля въведете телефон за доставка' };
    if (!PHONE_REGEX.test(trimmed.replace(/\s+/g, ''))) {
      return { ok: false, message: 'Невалиден телефонен номер (формат: +359XXXXXXXXX)' };
    }
    return { ok: true };
  }

  function setFieldState(fieldEl, errorEl, result) {
    if (!fieldEl) return;
    if (result.ok) {
      fieldEl.classList.remove('is-invalid');
      if (errorEl) errorEl.textContent = '';
    } else {
      fieldEl.classList.add('is-invalid');
      if (errorEl) errorEl.textContent = result.message;
    }
  }

  function savePhoneToCart(phone) {
    return fetch('/cart/update.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
      body: JSON.stringify({ attributes: { 'Delivery phone': phone } })
    }).then(function (r) {
      if (!r.ok) throw new Error('cart update failed');
      return r.json();
    });
  }

  function wirePhoneField(inputId, errorId, ctaId) {
    var input = $(inputId);
    var errorEl = $(errorId);
    var cta = $(ctaId);
    if (!input || !cta) return;
    var fieldEl = input.closest('.mp-phone-field');

    try {
      var saved = window.localStorage && window.localStorage.getItem(PHONE_STORAGE_KEY);
      if (saved && !input.value) input.value = saved;
    } catch (e) { /* localStorage may be blocked */ }

    input.addEventListener('blur', function () {
      setFieldState(fieldEl, errorEl, validatePhoneValue(input.value));
    });
    input.addEventListener('input', function () {
      if (fieldEl && fieldEl.classList.contains('is-invalid')) {
        setFieldState(fieldEl, errorEl, validatePhoneValue(input.value));
      }
    });

    cta.addEventListener('click', function (e) {
      var result = validatePhoneValue(input.value);
      if (!result.ok) {
        e.preventDefault();
        setFieldState(fieldEl, errorEl, result);
        input.focus();
        return;
      }
      e.preventDefault();
      var normalized = normalizePhone(input.value);
      input.value = normalized;
      try {
        if (window.localStorage) window.localStorage.setItem(PHONE_STORAGE_KEY, normalized);
      } catch (err) { /* ignore */ }
      cta.classList.add('is-disabled');
      savePhoneToCart(normalized)
        .catch(function (err) { console.error('[Habits] phone save failed:', err); })
        .then(function () {
          window.location.href = cta.getAttribute('href') || '/checkout';
        });
    });
  }

  wirePhoneField('#mp-drawer-phone', '#mp-drawer-phone-error', '#mp-drawer-cta');
  wirePhoneField('#mp-sheet-phone', '#mp-sheet-phone-error', '#mp-sheet-cta');

  /* ─────────── Upsell modal ─────────── */
  var previewImg = $('#mp-upsell-preview-img');
  var previewName = $('#mp-upsell-preview-name');
  var previewPrice = $('#mp-upsell-preview-price');

  function openUpsell(variantId, card) {
    state.pendingVariant = variantId;
    state.upsellOpen = true;

    // Reset selections
    $$('.mp-upsell__check').forEach(function (c) { c.checked = false; });
    $$('.mp-addon-tile.is-selected').forEach(function (t) { t.classList.remove('is-selected'); });

    // Populate product preview from the clicked card
    if (card) {
      if (previewImg) {
        previewImg.src = card.dataset.productImage || '';
        previewImg.alt = card.dataset.productTitle || '';
      }
      if (previewName) previewName.textContent = card.dataset.productTitle || '';
      if (previewPrice) previewPrice.textContent = card.dataset.productPrice || '';
    }

    if (upsell) upsell.classList.add('is-open');
    if (upsellOverlay) upsellOverlay.classList.add('is-open');
    document.body.style.overflow = 'hidden';
  }

  function closeUpsell() {
    state.upsellOpen = false;
    state.pendingVariant = null;
    if (upsell) upsell.classList.remove('is-open');
    if (upsellOverlay) upsellOverlay.classList.remove('is-open');
    document.body.style.overflow = '';
  }

  function collectUpsellItems() {
    var items = [];
    // Main product
    if (state.pendingVariant) {
      items.push({ id: parseInt(state.pendingVariant, 10), quantity: 1 });
    }
    // Checked addons
    $$('.mp-upsell__check:checked').forEach(function (c) {
      items.push({ id: parseInt(c.value, 10), quantity: 1 });
    });
    return items;
  }

  if (upsellClose) upsellClose.addEventListener('click', closeUpsell);
  if (upsellOverlay) upsellOverlay.addEventListener('click', closeUpsell);

  // Upsell action buttons (single page: skip-all or add)
  $$('.mp-upsell__next, .mp-upsell__skip').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var action = btn.dataset.action;
      if (action === 'skip-all') {
        // "Не искам добавка" = add only the main item, no addons
        var items = [{ id: parseInt(state.pendingVariant, 10), quantity: 1 }];
        addToCart(items).then(function () {
          closeUpsell();
          bounceCartBadge();
        });
      } else if (action === 'add') {
        // "Добави в количката" = add main item + selected addons
        var items = collectUpsellItems();
        if (items.length > 0) {
          addToCart(items).then(function () {
            closeUpsell();
            bounceCartBadge();
          });
        }
      }
    });
  });

  /* ─────────── Addon tile interactions ─────────── */
  var productPopupOverlay = $('#mp-product-popup-overlay');
  var productPopup = $('#mp-product-popup');
  var productPopupBack = $('#mp-product-popup-back');
  var productPopupImgWrap = $('#mp-product-popup-img-wrap');
  var productPopupTitle = $('#mp-product-popup-title');
  var productPopupPrice = $('#mp-product-popup-price');
  var productPopupDesc = $('#mp-product-popup-desc');
  var productPopupAddBtn = $('#mp-product-popup-add');
  var currentPopupTile = null;

  // Tile click: toggles selection
  document.addEventListener('click', function (e) {
    var tile = e.target.closest('.mp-addon-tile');
    if (!tile) return;
    toggleTileSelection(tile);
  });

  function toggleTileSelection(tile) {
    var checkbox = tile.querySelector('.mp-addon-tile__input');
    if (!checkbox) return;
    checkbox.checked = !checkbox.checked;
    tile.classList.toggle('is-selected', checkbox.checked);
  }

  function openProductPopup(tile) {
    currentPopupTile = tile;
    var imgSrc = tile.dataset.productImage;
    var title = tile.dataset.productTitle;
    var price = tile.dataset.productPrice;
    var desc = tile.dataset.productDescription || '';

    if (productPopupImgWrap) {
      productPopupImgWrap.innerHTML = imgSrc
        ? '<img src="' + imgSrc + '" alt="' + title + '" loading="lazy">'
        : '';
    }
    if (productPopupTitle) productPopupTitle.textContent = title;
    if (productPopupPrice) productPopupPrice.textContent = price;
    if (productPopupDesc) productPopupDesc.textContent = desc;

    if (productPopup) productPopup.classList.add('is-open');
    if (productPopupOverlay) productPopupOverlay.classList.add('is-open');
  }

  function closeProductPopup() {
    if (productPopup) productPopup.classList.remove('is-open');
    if (productPopupOverlay) productPopupOverlay.classList.remove('is-open');
    currentPopupTile = null;
  }

  if (productPopupBack) productPopupBack.addEventListener('click', closeProductPopup);
  if (productPopupOverlay) productPopupOverlay.addEventListener('click', closeProductPopup);

  // Product popup add button: selects the tile and closes popup
  if (productPopupAddBtn) {
    productPopupAddBtn.addEventListener('click', function () {
      if (currentPopupTile) {
        var checkbox = currentPopupTile.querySelector('.mp-addon-tile__input');
        if (checkbox && !checkbox.checked) {
          checkbox.checked = true;
          currentPopupTile.classList.add('is-selected');
        }
      }
      closeProductPopup();
    });
  }

  /* ─────────── Product card click (whole card) ─────────── */
  document.addEventListener('click', function (e) {
    var card = e.target.closest('.mp-card');
    if (!card) return;

    var variantId = card.dataset.variantId;
    if (!variantId) return;

    var hasAddons = $('#mp-upsell-list-1 .mp-addon-tile');

    if (hasAddons) {
      openUpsell(variantId, card);
    } else {
      addToCart([{ id: parseInt(variantId, 10), quantity: 1 }]).then(bounceCartBadge);
    }
  });

  /* ─────────── Init ─────────── */
  function init() {
    fetchCart();
    initTimeLogic();

    // Dismiss loader
    setTimeout(function () {
      if (loader) loader.classList.add('is-hidden');
      setTimeout(function () { if (loader) loader.style.display = 'none'; }, 500);
    }, 600);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
})();
</script>

