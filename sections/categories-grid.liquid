{% liquid
  assign has_heading_image = false
  if section.settings.heading_image != blank
    assign has_heading_image = true
  endif
%}

<div
  id="CategoriesGrid-{{ section.id }}"
  class="categories-grid"
  style="
    --cg-radius: {{ section.settings.border_radius | default: 24 }}px;
    --cg-margin: {{ section.settings.section_margin | default: 12 }}px;
    --cg-bg: {{ section.settings.background_color | default: '#4a8f6d' }};
    --cg-card-bg: {{ section.settings.card_color | default: '#2d5e45' }};
    --cg-columns: {{ section.blocks.size | at_most: 6 }};
    --cg-card-gap: {{ section.settings.card_gap | default: 20 }}px;
    --cg-heading-size: {{ section.settings.heading_image_size | default: 160 }}px;
    --cg-section-spacing: {{ section.settings.section_spacing | default: 20 }}px;
    --cg-gradient-color: {{ section.settings.gradient_color | default: '#000000' }};
    --cg-gradient-opacity: {{ section.settings.gradient_opacity | divided_by: 100.0 }};
    --cg-title-color: {{ section.settings.card_title_color | default: '#ffffff' }};
  "
>
  <div class="categories-grid__container spacing-style" style="{% render 'spacing-style', settings: section.settings %}">

    {%- comment -%} Heading image (e.g. logo) {%- endcomment -%}
    {% if has_heading_image %}
      <div class="categories-grid__heading">
        {{
          section.settings.heading_image
          | image_url: width: 600
          | image_tag:
            loading: 'lazy',
            widths: '120, 160, 240, 320, 480, 600',
            sizes: '(max-width: 749px) 120px, 160px',
            class: 'categories-grid__heading-img'
        }}
      </div>
    {% elsif section.settings.title != blank %}
      <h2 class="categories-grid__title">{{ section.settings.title }}</h2>
    {% endif %}

    {%- comment -%} Cards carousel {%- endcomment -%}
    <div class="categories-grid__carousel">
      <button
        class="categories-grid__arrow categories-grid__arrow--prev"
        type="button"
        aria-label="Previous"
        data-carousel-prev="{{ section.id }}"
      >
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="15 18 9 12 15 6"></polyline>
        </svg>
      </button>

      <div class="categories-grid__cards">
        <div class="categories-grid__track" data-carousel-track="{{ section.id }}">
          {% for block in section.blocks %}
            <div class="categories-grid__card{% if forloop.first %} categories-grid__card--active{% endif %}" data-card-index="{{ forloop.index0 }}" {{ block.shopify_attributes }}>
              {% if block.settings.link != blank %}
                <a href="{{ block.settings.link }}" class="categories-grid__card-link">
              {% endif %}

              <div class="categories-grid__arch">
                {%- comment -%} Background image {%- endcomment -%}
                {% if block.settings.image != blank %}
                  {{
                    block.settings.image
                    | image_url: width: 800
                    | image_tag:
                      loading: 'lazy',
                      sizes: '(max-width: 749px) 55vw, 25vw',
                      widths: '200, 300, 400, 600, 800',
                      class: 'categories-grid__card-img'
                  }}
                {% endif %}

                {%- comment -%} Gradient overlay {%- endcomment -%}
                <div class="categories-grid__card-gradient"></div>

                {%- comment -%} Title: logo image or text {%- endcomment -%}
                {% if block.settings.title_image != blank %}
                  <div class="categories-grid__card-logo">
                    {{
                      block.settings.title_image
                      | image_url: width: 400
                      | image_tag:
                        loading: 'lazy',
                        class: 'categories-grid__card-logo-img',
                        style: 'width: ' | append: block.settings.title_image_width | append: 'px'
                    }}
                  </div>
                {% elsif block.settings.title != blank %}
                  <h1 class="categories-grid__card-title">{{ block.settings.title }}</h1>
                {% endif %}
              </div>

              {% if block.settings.link != blank %}
                </a>
              {% endif %}
            </div>
          {% endfor %}
        </div>
      </div>

      <button
        class="categories-grid__arrow categories-grid__arrow--next"
        type="button"
        aria-label="Next"
        data-carousel-next="{{ section.id }}"
      >
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="9 18 15 12 9 6"></polyline>
        </svg>
      </button>
    </div>

  </div>
</div>

<script>
  (function() {
    var sectionId = '{{ section.id }}';
    var track = document.querySelector('[data-carousel-track="' + sectionId + '"]');
    var prevBtn = document.querySelector('[data-carousel-prev="' + sectionId + '"]');
    var nextBtn = document.querySelector('[data-carousel-next="' + sectionId + '"]');
    if (!track || !prevBtn || !nextBtn) return;

    var cards = track.querySelectorAll('.categories-grid__card');
    var total = cards.length;
    var current = 0;

    function update() {
      cards.forEach(function(card, i) {
        card.classList.toggle('categories-grid__card--active', i === current);
      });
      prevBtn.disabled = current === 0;
      nextBtn.disabled = current === total - 1;
    }

    prevBtn.addEventListener('click', function() {
      if (current > 0) { current--; update(); }
    });

    nextBtn.addEventListener('click', function() {
      if (current < total - 1) { current++; update(); }
    });

    update();
  })();
</script>

{% stylesheet %}
  /* Outer frame */
  .categories-grid-section {
    margin-block: var(--cg-section-spacing, 20px);
  }

  .categories-grid {
    margin-inline: var(--cg-margin, 12px);
  }

  .categories-grid__container {
    background: var(--cg-bg);
    border-radius: var(--cg-radius, 24px);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 32px;
  }

  /* Heading image / text */
  .categories-grid__heading {
    display: flex;
    justify-content: center;
  }

  .categories-grid__heading-img {
    width: var(--cg-heading-size, 160px);
    height: auto;
    object-fit: contain;
  }

  .categories-grid__title {
    margin: 0;
    color: #fff;
    font-size: clamp(1.5rem, 3vw, 2.5rem);
    text-align: center;
  }

  /* Carousel wrapper */
  .categories-grid__carousel {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    width: 100%;
    padding-inline: 16px;
    box-sizing: border-box;
  }

  /* Arrow buttons */
  .categories-grid__arrow {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    border: 2px solid rgba(255, 255, 255, 0.4);
    background: rgba(255, 255, 255, 0.1);
    color: #fff;
    cursor: pointer;
    flex-shrink: 0;
    transition: background 0.2s, border-color 0.2s, opacity 0.2s;
  }

  .categories-grid__arrow:hover {
    background: rgba(255, 255, 255, 0.2);
    border-color: rgba(255, 255, 255, 0.7);
  }

  .categories-grid__arrow:disabled {
    opacity: 0.3;
    cursor: default;
  }

  /* Cards area — single card visible */
  .categories-grid__cards {
    width: 100%;
    max-width: 280px;
    overflow: hidden;
  }

  .categories-grid__track {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  /* All cards hidden by default, active one shown */
  .categories-grid__card {
    display: none;
    width: 100%;
  }

  .categories-grid__card--active {
    display: block;
    animation: cg-fade-in 0.35s ease;
  }

  @keyframes cg-fade-in {
    from { opacity: 0; transform: scale(0.95); }
    to   { opacity: 1; transform: scale(1); }
  }

  /* Individual card */
  .categories-grid__card-link {
    text-decoration: none;
    color: inherit;
    display: block;
  }

  .categories-grid__arch {
    position: relative;
    width: 100%;
    aspect-ratio: 3 / 4;
    background: var(--cg-card-bg);
    border-radius: 9999px 9999px 0 0;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-end;
    transition: transform 0.3s ease;
  }

  .categories-grid__card-link:hover .categories-grid__arch {
    transform: scale(1.02);
  }

  /* Image as full background */
  .categories-grid__card-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  /* Gradient overlay from bottom */
  .categories-grid__card-gradient {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    background: linear-gradient(
      to top,
      rgb(from var(--cg-gradient-color) r g b / var(--cg-gradient-opacity)) 0%,
      rgb(from var(--cg-gradient-color) r g b / calc(var(--cg-gradient-opacity) * 0.5)) 40%,
      transparent 70%
    );
    border-radius: inherit;
  }

  /* Title: large heading */
  .categories-grid__card-title {
    position: relative;
    z-index: 2;
    color: var(--cg-title-color, #fff);
    margin: 0;
    font-size: clamp(1.25rem, 2vw, 1.75rem);
    font-weight: 700;
    text-align: center;
    line-height: 1.15;
    padding: 16px 12px 20px;
    width: 100%;
    word-break: break-word;
    hyphens: auto;
  }

  /* Title logo image */
  .categories-grid__card-logo {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 16px 12px 20px;
  }

  .categories-grid__card-logo-img {
    height: auto;
    object-fit: contain;
    max-width: 80%;
    display: block;
  }

  /* Mobile adjustments */
  @media screen and (max-width: 749px) {
    .categories-grid__container {
      gap: 24px;
    }

    .categories-grid__cards {
      max-width: 240px;
    }

    .categories-grid__arrow {
      width: 40px;
      height: 40px;
    }

    .categories-grid__arrow svg {
      width: 20px;
      height: 20px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Categories grid",
  "tag": "section",
  "class": "categories-grid-section",
  "settings": [
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "image_picker",
      "id": "heading_image",
      "label": "Heading image",
      "info": "Logo or decorative heading. Takes priority over text heading."
    },
    {
      "type": "range",
      "id": "heading_image_size",
      "label": "Heading image width",
      "min": 60,
      "max": 400,
      "step": 10,
      "unit": "px",
      "default": 160
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading text",
      "default": "Our categories",
      "info": "Used when no heading image is set"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#4a8f6d"
    },
    {
      "type": "color",
      "id": "card_color",
      "label": "Card color",
      "default": "#2d5e45"
    },
    {
      "type": "color",
      "id": "card_title_color",
      "label": "Card title color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Card gradient"
    },
    {
      "type": "color",
      "id": "gradient_color",
      "label": "Gradient color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "gradient_opacity",
      "label": "Gradient intensity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 70,
      "info": "0% = no gradient, 100% = fully opaque"
    },
    {
      "type": "header",
      "content": "Card shape"
    },
    {
      "type": "range",
      "id": "card_gap",
      "label": "Gap between cards",
      "min": 8,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 20
    },
    {
      "type": "header",
      "content": "Rounded container"
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Corner radius",
      "min": 0,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "section_margin",
      "label": "Outer spacing",
      "min": 0,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "section_spacing",
      "label": "Space above & below section",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 20
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 48
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Background image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Category"
        },
        {
          "type": "image_picker",
          "id": "title_image",
          "label": "Title logo",
          "info": "Use a logo/icon instead of text. Takes priority over title text."
        },
        {
          "type": "range",
          "id": "title_image_width",
          "label": "Logo width",
          "min": 40,
          "max": 200,
          "step": 5,
          "unit": "px",
          "default": 100
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Categories grid",
      "category": "Collection",
      "blocks": [
        { "type": "category", "settings": { "title": "Hookah" } },
        { "type": "category", "settings": { "title": "Food" } },
        { "type": "category", "settings": { "title": "Drinks" } },
        { "type": "category", "settings": { "title": "Delivery" } }
      ]
    }
  ]
}
{% endschema %}
