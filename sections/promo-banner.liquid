{% liquid
  assign has_image = false
  if section.settings.image != blank
    assign has_image = true
  endif

  assign has_heading_image = false
  if section.settings.heading_image != blank
    assign has_heading_image = true
  endif

  assign has_badge_1 = false
  if section.settings.badge_icon_1 != blank
    assign has_badge_1 = true
  endif

  assign has_badge_2 = false
  if section.settings.badge_icon_2 != blank
    assign has_badge_2 = true
  endif
%}

<div
  id="PromoBanner-{{ section.id }}"
  class="promo-banner"
  style="
    --pb-bg: {{ section.settings.background_color | default: '#4a8f6d' }};
    --pb-radius: {{ section.settings.border_radius | default: 24 }}px;
    --pb-margin: {{ section.settings.section_margin | default: 12 }}px;
    --pb-heading-size: {{ section.settings.heading_image_size | default: 200 }}px;
    --pb-section-spacing: {{ section.settings.section_spacing | default: 20 }}px;
    --pb-image-radius: {{ section.settings.image_radius | default: 16 }}px;
    --pb-badge-size: {{ section.settings.badge_size | default: 56 }}px;
  "
>
  {%- comment -%} Background shape — rounded, sits behind everything {%- endcomment -%}
  <div class="promo-banner__bg"></div>

  {%- comment -%} Content grid {%- endcomment -%}
  <div
    class="promo-banner__grid spacing-style"
    style="{% render 'spacing-style', settings: section.settings %}"
  >
    {%- comment -%} Left: contained rounded image {%- endcomment -%}
    {% if has_image %}
      <div class="promo-banner__media">
        {{
          section.settings.image
          | image_url: width: 1200
          | image_tag:
            loading: 'lazy',
            sizes: '(max-width: 749px) 90vw, 45vw',
            widths: '375, 550, 750, 1000, 1200',
            class: 'promo-banner__img'
        }}
      </div>
    {% endif %}

    {%- comment -%} Right: heading + text + badges + CTA {%- endcomment -%}
    <div class="promo-banner__content">
      {% if has_heading_image %}
        <div class="promo-banner__heading-image">
          {{
            section.settings.heading_image
            | image_url: width: 800
            | image_tag:
              loading: 'lazy',
              widths: '150, 200, 300, 400, 600, 800',
              sizes: '(max-width: 749px) 50vw, 30vw',
              class: 'promo-banner__heading-img'
          }}
        </div>
      {% elsif section.settings.title != blank %}
        <h2 class="promo-banner__title">{{ section.settings.title }}</h2>
      {% endif %}

      {% if section.settings.text != blank %}
        <div class="promo-banner__text rte">{{ section.settings.text }}</div>
      {% endif %}

      {%- comment -%} Badge icons row {%- endcomment -%}
      {% if has_badge_1 or has_badge_2 %}
        <div class="promo-banner__badges">
          {% if has_badge_1 %}
            <div class="promo-banner__badge">
              {{
                section.settings.badge_icon_1
                | image_url: width: 200
                | image_tag:
                  loading: 'lazy',
                  class: 'promo-banner__badge-icon'
              }}
            </div>
          {% endif %}
          {% if has_badge_2 %}
            <div class="promo-banner__badge">
              {{
                section.settings.badge_icon_2
                | image_url: width: 200
                | image_tag:
                  loading: 'lazy',
                  class: 'promo-banner__badge-icon'
              }}
            </div>
          {% endif %}
        </div>
      {% endif %}

      {% if section.settings.button_label != blank %}
        <a
          href="{{ section.settings.button_link }}"
          class="promo-banner__button button {{ section.settings.button_style }}"
          {% if section.settings.button_open_new_tab %}target="_blank" rel="noopener"{% endif %}
        >
          {{ section.settings.button_label }}
        </a>
      {% endif %}
    </div>
  </div>
</div>

{% stylesheet %}
  .promo-banner-section {
    margin-block: var(--pb-section-spacing, 20px);
  }

  .promo-banner {
    position: relative;
    margin-inline: var(--pb-margin, 12px);
  }

  /* Background shape with rounded corners */
  .promo-banner__bg {
    position: absolute;
    inset: 0;
    background: var(--pb-bg);
    border-radius: var(--pb-radius, 24px);
    z-index: 0;
  }

  /* Side-by-side layout — image left, content right */
  .promo-banner__grid {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 40px;
  }

  /* ─── Left: rounded image ─── */
  .promo-banner__media {
    position: relative;
    border-radius: var(--pb-image-radius, 16px);
    overflow: hidden;
    width: 45%;
    flex-shrink: 0;
    aspect-ratio: 4 / 3;
  }

  .promo-banner__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* ─── Right: content ─── */
  .promo-banner__content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 16px;
    flex: 1;
    min-width: 0;
  }

  .promo-banner__heading-image {
    display: flex;
  }

  .promo-banner__heading-img {
    width: var(--pb-heading-size, 200px);
    height: auto;
    object-fit: contain;
  }

  .promo-banner__title {
    margin: 0;
    color: #fff;
    font-size: clamp(2rem, 5vw, 4rem);
    line-height: 1.05;
    font-weight: 800;
  }

  .promo-banner__text {
    color: #fff;
    font-size: clamp(0.8125rem, 1.2vw, 1rem);
    line-height: 1.65;
    max-width: 480px;
  }

  .promo-banner__button {
    margin-block-start: 4px;
    border-radius: 8px;
    padding-block: 10px;
    padding-inline: 28px;
    font-size: 0.875rem;
  }

  /* ─── Badges ─── */
  .promo-banner__badges {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-block: 4px;
  }

  .promo-banner__badge {
    width: var(--pb-badge-size, 56px);
    height: var(--pb-badge-size, 56px);
    background: #fff;
    border-radius: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 10px;
    flex-shrink: 0;
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.06);
  }

  .promo-banner__badge-icon {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
  }

  /* ─── Mobile ─── */
  @media screen and (max-width: 749px) {
    .promo-banner__grid {
      flex-direction: column;
      align-items: flex-start;
      gap: 20px;
    }

    .promo-banner__media {
      width: 75%;
      align-self: flex-start;
    }

    .promo-banner__content {
      align-items: flex-start;
      padding-inline: 4px;
    }

    .promo-banner__heading-img {
      width: min(var(--pb-heading-size, 200px), 55vw);
    }

    .promo-banner__title {
      font-size: clamp(1.75rem, 8vw, 2.5rem);
    }

    .promo-banner__text {
      font-size: 0.875rem;
    }

    .promo-banner__badges {
      gap: 12px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Promo banner",
  "tag": "section",
  "class": "promo-banner-section",
  "settings": [
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "image_picker",
      "id": "heading_image",
      "label": "Heading image",
      "info": "Logo or jumbo heading image. Takes priority over text."
    },
    {
      "type": "range",
      "id": "heading_image_size",
      "label": "Heading image width",
      "min": 80,
      "max": 500,
      "step": 10,
      "unit": "px",
      "default": 200
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading text",
      "default": "Promo banner",
      "info": "Used when no heading image is set"
    },
    {
      "type": "header",
      "content": "Text & button"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Add a short promotional message here.</p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Shop now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "select",
      "id": "button_style",
      "label": "Button style",
      "options": [
        { "value": "button-primary", "label": "Primary" },
        { "value": "button-secondary", "label": "Secondary" },
        { "value": "button-tertiary", "label": "Tertiary" }
      ],
      "default": "button-primary"
    },
    {
      "type": "checkbox",
      "id": "button_open_new_tab",
      "label": "Open in new tab",
      "default": false
    },
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image",
      "info": "Fills the rounded frame on the left side (object-fit: cover)"
    },
    {
      "type": "range",
      "id": "image_radius",
      "label": "Image corner radius",
      "min": 0,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "header",
      "content": "Badge icons"
    },
    {
      "type": "paragraph",
      "content": "Two white badges for logos or icons. Fixed size ensures consistent appearance."
    },
    {
      "type": "image_picker",
      "id": "badge_icon_1",
      "label": "Badge icon 1"
    },
    {
      "type": "image_picker",
      "id": "badge_icon_2",
      "label": "Badge icon 2"
    },
    {
      "type": "range",
      "id": "badge_size",
      "label": "Badge size",
      "min": 40,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 56
    },
    {
      "type": "header",
      "content": "Container"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#4a8f6d"
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Corner radius",
      "min": 0,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "section_margin",
      "label": "Outer spacing",
      "min": 0,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "section_spacing",
      "label": "Space above & below section",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 20
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding-inline-start",
      "label": "Left",
      "min": 0,
      "max": 80,
      "step": 1,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding-inline-end",
      "label": "Right",
      "min": 0,
      "max": 80,
      "step": 1,
      "unit": "px",
      "default": 40
    }
  ],
  "presets": [
    {
      "name": "Promo banner",
      "category": "Promotional"
    }
  ]
}
{% endschema %}
