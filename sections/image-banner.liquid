{% liquid
  assign has_image = false
  if section.settings.image != blank
    assign has_image = true
  endif

  assign has_logo = false
  if section.settings.logo_image != blank
    assign has_logo = true
  endif
%}

<div
  id="ImageBanner-{{ section.id }}"
  class="image-banner color-{{ section.settings.color_scheme }}"
  style="
    --ib-arch-color: {{ section.settings.arch_color | default: '#4a8f6d' }};
    --ib-arch-radius: {{ section.settings.arch_radius | default: 50 }}%;
    --ib-logo-size: {{ section.settings.logo_size | default: 60 }}px;
    --ib-section-spacing: {{ section.settings.section_spacing | default: 20 }}px;
  "
>
  <div
    class="image-banner__grid spacing-style"
    style="{% render 'spacing-style', settings: section.settings %}"
  >
    {%- comment -%} Left: Arch-shaped image/color block {%- endcomment -%}
    <div class="image-banner__arch">
      <div class="image-banner__arch-inner">
        {% if has_image %}
          {{
            section.settings.image
            | image_url: width: 1500
            | image_tag:
              loading: 'lazy',
              sizes: '(max-width: 749px) 100vw, 45vw',
              widths: '375, 550, 750, 1100, 1500',
              class: 'image-banner__arch-img'
          }}
        {% endif %}

        {%- comment -%} Logo mark at bottom of arch {%- endcomment -%}
        {% if has_logo %}
          <div class="image-banner__logo">
            {{
              section.settings.logo_image
              | image_url: width: 300
              | image_tag:
                loading: 'lazy',
                widths: '40, 60, 80, 120, 160, 300',
                sizes: '(max-width: 749px) 50px, 60px',
                class: 'image-banner__logo-img'
            }}
          </div>
        {% endif %}
      </div>
    </div>

    {%- comment -%} Right: Content {%- endcomment -%}
    <div
      class="image-banner__content"
      style="
        --ib-heading-align: {{ section.settings.heading_alignment | default: 'center' }};
        --ib-text-align: {{ section.settings.text_alignment | default: 'center' }};
        --ib-button-align: {{ section.settings.button_alignment | default: 'flex-end' }};
      "
    >
      {% if section.settings.title != blank %}
        <h2 class="image-banner__title">{{ section.settings.title }}</h2>
      {% endif %}

      {% if section.settings.text != blank %}
        <div class="image-banner__text rte">{{ section.settings.text }}</div>
      {% endif %}

      {% if section.settings.button_label != blank %}
        <div class="image-banner__cta">
          <a
            href="{{ section.settings.button_link }}"
            class="image-banner__button button {{ section.settings.button_style }}"
            {% if section.settings.button_open_new_tab %}target="_blank" rel="noopener"{% endif %}
          >
            {{ section.settings.button_label }}
          </a>
        </div>
      {% endif %}
    </div>
  </div>
</div>

{% stylesheet %}
  .image-banner-section {
    margin-block: var(--ib-section-spacing, 20px);
  }

  .image-banner__grid {
    display: grid;
    grid-template-columns: 5fr 7fr;
    gap: 48px;
    align-items: center;
    max-width: 960px;
    margin-inline: auto;
    padding-inline: var(--spacing-inline, 24px);
  }

  /* Arch shape: rounded top, flat bottom */
  .image-banner__arch {
    position: relative;
    width: 100%;
    max-width: 340px;
  }

  .image-banner__arch-inner {
    position: relative;
    width: 100%;
    aspect-ratio: 3 / 4;
    background: var(--ib-arch-color);
    border-radius: var(--ib-arch-radius) var(--ib-arch-radius) 0 0;
    overflow: hidden;
    display: flex;
    align-items: flex-end;
    justify-content: center;
  }

  .image-banner__arch-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .image-banner__logo {
    position: relative;
    z-index: 2;
    padding-block-end: 32px;
  }

  .image-banner__logo-img {
    width: var(--ib-logo-size, 60px);
    height: auto;
    object-fit: contain;
  }

  /* Right content column */
  .image-banner__content {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .image-banner__title {
    margin: 0;
    color: var(--color-foreground);
    font-size: clamp(1.75rem, 3.5vw, 2.75rem);
    line-height: 1.15;
    text-align: var(--ib-heading-align, center);
  }

  .image-banner__text {
    color: var(--color-foreground);
    font-size: clamp(0.875rem, 1.1vw, 1rem);
    line-height: 1.7;
    text-align: var(--ib-text-align, center);
  }

  .image-banner__cta {
    display: flex;
    justify-content: var(--ib-button-align, flex-end);
    width: 100%;
    margin-block-start: 4px;
  }

  .image-banner__button {
    border-radius: 8px;
    padding-block: 10px;
    padding-inline: 28px;
    font-size: 0.875rem;
  }

  /* Mobile: stack vertically */
  @media screen and (max-width: 749px) {
    .image-banner__grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }

    .image-banner__arch-inner {
      max-width: 340px;
      margin-inline: auto;
    }

    .image-banner__content {
      --ib-heading-align: center !important;
      --ib-text-align: center !important;
      --ib-button-align: center !important;
      align-items: center;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Image banner",
  "tag": "section",
  "class": "image-banner-section",
  "settings": [
    {
      "type": "header",
      "content": "Arch image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image",
      "info": "Optional. Without an image the arch shows a solid color."
    },
    {
      "type": "color",
      "id": "arch_color",
      "label": "Arch background color",
      "default": "#4a8f6d"
    },
    {
      "type": "range",
      "id": "arch_radius",
      "label": "Arch roundness",
      "min": 20,
      "max": 50,
      "step": 1,
      "unit": "%",
      "default": 50,
      "info": "50% = full semicircle top"
    },
    {
      "type": "header",
      "content": "Logo mark"
    },
    {
      "type": "image_picker",
      "id": "logo_image",
      "label": "Logo image",
      "info": "Displayed at the bottom of the arch"
    },
    {
      "type": "range",
      "id": "logo_size",
      "label": "Logo size",
      "min": 30,
      "max": 150,
      "step": 5,
      "unit": "px",
      "default": 60
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Your heading"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Pair text with an image to focus on your chosen product, collection, or blog post.</p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Shop now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "select",
      "id": "button_style",
      "label": "Button style",
      "options": [
        { "value": "button-primary", "label": "Primary" },
        { "value": "button-secondary", "label": "Secondary" },
        { "value": "button-tertiary", "label": "Tertiary" }
      ],
      "default": "button-primary"
    },
    {
      "type": "checkbox",
      "id": "button_open_new_tab",
      "label": "Open in new tab",
      "default": false
    },
    {
      "type": "header",
      "content": "Desktop alignment",
      "info": "On mobile everything is centered automatically"
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "Heading alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "button_alignment",
      "label": "Button alignment",
      "options": [
        { "value": "flex-start", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "flex-end", "label": "Right" }
      ],
      "default": "flex-end"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "Color scheme",
      "options": [
        { "value": "scheme-1", "label": "Scheme 1" },
        { "value": "scheme-2", "label": "Scheme 2" },
        { "value": "scheme-3", "label": "Scheme 3" },
        { "value": "scheme-4", "label": "Scheme 4" },
        { "value": "scheme-5", "label": "Scheme 5" },
        { "value": "scheme-6", "label": "Scheme 6" }
      ],
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "section_spacing",
      "label": "Space above & below section",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 20
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 48
    }
  ],
  "presets": [
    {
      "name": "Image banner",
      "category": "Image"
    }
  ]
}
{% endschema %}
