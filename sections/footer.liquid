

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div
  class="section section--{{ section.settings.section_width }} color-{{ section.settings.color_scheme }}"
>
  {% liquid
    assign total_blocks = section.blocks.size

    # Grid layout calculations
    assign grid_columns = total_blocks | at_most: 4

    # Calculate last row counts using modulo arithmetic
    # last_row_count = (total_blocks - 1) % N + 1
    assign last_row_count = total_blocks | minus: 1 | modulo: 4 | plus: 1
    assign tablet_last_row_count = total_blocks | minus: 1 | modulo: 2 | plus: 1

    # Check if there are orphaned elements (single item in last row)
    assign has_isolated_grid_item_desktop = false
    assign has_isolated_grid_item_tablet = false

    if total_blocks > 4 and last_row_count == 1
      assign has_isolated_grid_item_desktop = true
    endif

    if total_blocks == 5
      assign has_isolated_grid_item_tablet = true
    endif
  %}
  <div
    class="
      footer-content
      spacing-style
      {% if has_isolated_grid_item_desktop %}footer-content--isolated-grid-item-desktop{% endif %}
      {% if has_isolated_grid_item_tablet %}footer-content--isolated-grid-item-tablet{% endif %}
    "
    style="
      {%  render 'spacing-style', settings: section.settings %}
      --footer-gap: {{ section.settings.gap }}px;
      --grid-columns: {{ grid_columns }};
      --last-row-count: {{ last_row_count }};
      --tablet-last-row-count: {{ tablet_last_row_count }};
    "
  >
    {% content_for 'blocks' %}
  </div>
</div>

{% stylesheet %}
  .footer-content {
    contain: content;
    content-visibility: auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--footer-gap);
  }

  @media screen and (min-width: 750px) and (max-width: 989px) {
    .footer-content {
      grid-template-columns: repeat(min(var(--grid-columns), 3), 1fr);
      grid-auto-flow: row;
    }

    .footer-content[style*='--grid-columns: 4'] {
      grid-template-columns: repeat(2, 1fr);
    }

    .footer-content--isolated-grid-item-tablet > :last-child {
      grid-column: 1 / -1;
    }
  }

  @media screen and (min-width: 990px) {
    .footer-content {
      grid-template-columns: repeat(var(--grid-columns), 1fr);
    }

    /* Single item centered */
    .footer-content[style*='--grid-columns: 1'] {
      justify-items: center;
    }

    .footer-content--isolated-grid-item-desktop > :last-child {
      grid-column: 1 / -1;
    }
  }

  /* --- Habits footer polish (image-panel left + newsletter right) --- */

/* =========================================================
   EASILY ADJUSTABLE KNOBS
   - Logo watermark opacity: --footer-logo-opacity (around 0.85)
   - Panel corner radius:    --footer-panel-radius (store ~16-24px)
   - Panel min-heights:      --footer-panel-minh / --footer-panel-minh-mobile
   ========================================================= */
.footer-content {
  --footer-logo-opacity: 0.85;   /* watermark logo opacity — tweak here */
  --footer-panel-radius: 20px;   /* matches store rounded-card aesthetic */
  --footer-panel-minh: 420px;    /* desktop image-panel height */
  --footer-panel-minh-mobile: 220px;
}

/* 2-column band: image-panel left, newsletter right, stretched & roomy */
@media screen and (min-width: 990px) {
  .footer-content[style*='--grid-columns: 2'] {
    /* stretch so the image panel matches the newsletter column height */
    align-items: stretch;
    gap: clamp(2.5rem, 6vw, 5rem);
  }
  /* keep the newsletter from sprawling; vertically center it next to the panel */
  .footer-content[style*='--grid-columns: 2'] > :last-child {
    justify-self: end;
    align-self: center;
    max-width: 30rem;
  }
}

/* -------- LEFT: rounded image panel (the group with a bg image) -------- */
/* The left column's group-block IS the first grid child (no wrapper). */
.footer-content > :first-child {
  position: relative;                 /* base.css already sets this; explicit for safety */
  width: 100%;
  min-height: var(--footer-panel-minh);
  border-radius: var(--footer-panel-radius);
  overflow: hidden;                   /* clip image + overlay corners */
  /* subtle branded tint so the panel + logo read well even before an image is set */
  background-color: #024b40;          /* store green fallback */
}
/* Background media wrapper fills the panel behind the centered logo */
.footer-content > :first-child .group-block__media-wrapper {
  position: absolute;
  inset: 0;
}

/* Background image fills the panel, cover (real Horizon hooks) */
.footer-content > :first-child .background-image-container {
  border-radius: var(--footer-panel-radius);
}
.footer-content > :first-child .background-image-container img {
  object-fit: cover;
  width: 100%;
  height: 100%;
}

/* Overlay tint sits behind the logo for contrast; round its corners too */
.footer-content > :first-child .overlay {
  border-radius: var(--footer-panel-radius);
}

/* Center the logo watermark over the panel */
.footer-content > :first-child .group-block-content {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 100%;
  width: 100%;
  padding: 1.5rem;
}

/* The logo block: light/inverse asset, reduced opacity watermark */
.footer-content > :first-child .logo-block {
  pointer-events: none;
}
.footer-content > :first-child .logo-block__image {
  opacity: var(--footer-logo-opacity);  /* watermark — adjust via --footer-logo-opacity */
  max-width: 240px;
  height: auto;
}

/* -------- RIGHT: newsletter polish (carried forward) -------- */

/* Newsletter group reads as one tidy unit */
.footer-content .email-signup-block { margin-block-start: 0.25rem; }

/* White-on-green opacity tiers (store signature): headings solid, body softer.
   Scoped to the right column so the left panel logo opacity is untouched. */
.footer-content > :last-child p { opacity: 0.85; }
.footer-content > :last-child h1, .footer-content > :last-child h2,
.footer-content > :last-child h3, .footer-content > :last-child h4,
.footer-content > :last-child h5, .footer-content > :last-child h6 { opacity: 1; }

/* Email pill: crisp white field on green, near-black text, calm green focus ring */
.footer-content .email-signup__input-group--integrated {
  background: #ffffff;
  border-color: #ffffff;
}
.footer-content .email-signup__input {
  color: #1a1a1a;
  background: transparent;
}
.footer-content .email-signup__input::placeholder { color: #9a9a94; }
.footer-content .email-signup__input-group:focus-within {
  box-shadow: 0 0 0 2px rgba(74, 143, 109, 0.25);
}

/* Integrated "Запиши се" button keeps the scheme's orange primary, pill-matched */
.footer-content .email-signup__button.button { border-radius: 100px; }
.footer-content .email-signup__button.button:hover { opacity: 0.92; }

/* Soft, calm interactions (store signature 0.2s) */
.footer-content a,
.footer-content .email-signup__button { transition: opacity 0.2s ease; }

/* -------- Mobile: stack (panel on top, newsletter below) -------- */
@media screen and (max-width: 749px) {
  .footer-content { gap: 1.75rem; }
  .footer-content .email-signup-block { width: 100%; }

  /* image panel gets a sensible, shorter height when stacked */
  .footer-content > :first-child {
    min-height: var(--footer-panel-minh-mobile);
  }
}
{% endstylesheet %}

{% schema %}
{
  "name": "t:names.footer",
  "class": "section-wrapper",
  "blocks": [
    {
      "type": "_divider"
    },
    {
      "type": "@app"
    },
    {
      "type": "button"
    },
    {
      "type": "follow-on-shop"
    },
    {
      "type": "group"
    },
    {
      "type": "icon"
    },
    {
      "type": "image"
    },
    {
      "type": "menu"
    },
    {
      "type": "payment-icons"
    },
    {
      "type": "text"
    },
    {
      "type": "logo"
    },
    {
      "type": "jumbo-text"
    },
    {
      "type": "social-links"
    },
    {
      "type": "email-signup"
    }
  ],
  "enabled_on": {
    "groups": ["footer"]
  },
  "settings": [
    {
      "type": "select",
      "id": "section_width",
      "label": "t:settings.width",
      "options": [
        {
          "value": "page-width",
          "label": "t:options.page"
        },
        {
          "value": "full-width",
          "label": "t:options.full"
        }
      ],
      "default": "page-width"
    },
    {
      "type": "range",
      "id": "gap",
      "label": "t:settings.gap",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 20
    }
  ],
  "presets": [
    {
      "name": "t:names.footer",
      "category": "t:categories.footer",
      "settings": {
        "gap": 20,
        "color_scheme": "scheme-1",
        "padding-block-start": 36,
        "padding-block-end": 36
      },
      "blocks": {
        "newsletter-group": {
          "type": "group",
          "settings": {
            "content_direction": "column",
            "vertical_on_mobile": true,
            "horizontal_alignment": "flex-start",
            "vertical_alignment": "center",
            "gap": 6,
            "width": "fill",
            "inherit_color_scheme": true
          },
          "blocks": {
            "newsletter-heading": {
              "type": "text",
              "settings": {
                "text": "t:html_defaults.join_our_email_list",
                "width": "100%",
                "alignment": "left",
                "type_preset": "h3"
              }
            },
            "newsletter-text": {
              "type": "text",
              "settings": {
                "text": "t:html_defaults.get_exclusive_deals_and_early_access_to_new_products",
                "width": "100%",
                "alignment": "left",
                "type_preset": "rte"
              }
            }
          },
          "block_order": ["newsletter-heading", "newsletter-text"]
        },
        "newsletter-form": {
          "type": "email-signup",
          "settings": {
            "width": "fill"
          }
        }
      },
      "block_order": ["newsletter-group", "newsletter-form"]
    }
  ]
}
{% endschema %}
