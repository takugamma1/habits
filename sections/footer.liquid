

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div
  class="section section--{{ section.settings.section_width }} color-{{ section.settings.color_scheme }}"
>
  {% liquid
    assign total_blocks = section.blocks.size

    # Grid layout calculations
    assign grid_columns = total_blocks | at_most: 4

    # Calculate last row counts using modulo arithmetic
    # last_row_count = (total_blocks - 1) % N + 1
    assign last_row_count = total_blocks | minus: 1 | modulo: 4 | plus: 1
    assign tablet_last_row_count = total_blocks | minus: 1 | modulo: 2 | plus: 1

    # Check if there are orphaned elements (single item in last row)
    assign has_isolated_grid_item_desktop = false
    assign has_isolated_grid_item_tablet = false

    if total_blocks > 4 and last_row_count == 1
      assign has_isolated_grid_item_desktop = true
    endif

    if total_blocks == 5
      assign has_isolated_grid_item_tablet = true
    endif
  %}
  <div
    class="
      footer-content
      spacing-style
      {% if has_isolated_grid_item_desktop %}footer-content--isolated-grid-item-desktop{% endif %}
      {% if has_isolated_grid_item_tablet %}footer-content--isolated-grid-item-tablet{% endif %}
    "
    style="
      {%  render 'spacing-style', settings: section.settings %}
      --footer-gap: {{ section.settings.gap }}px;
      --grid-columns: {{ grid_columns }};
      --last-row-count: {{ last_row_count }};
      --tablet-last-row-count: {{ tablet_last_row_count }};
    "
  >
    {% content_for 'blocks' %}
  </div>
</div>

{% stylesheet %}
  .footer-content {
    contain: content;
    content-visibility: auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--footer-gap);
  }

  @media screen and (min-width: 750px) and (max-width: 989px) {
    .footer-content {
      grid-template-columns: repeat(min(var(--grid-columns), 3), 1fr);
      grid-auto-flow: row;
    }

    .footer-content[style*='--grid-columns: 4'] {
      grid-template-columns: repeat(2, 1fr);
    }

    .footer-content--isolated-grid-item-tablet > :last-child {
      grid-column: 1 / -1;
    }
  }

  @media screen and (min-width: 990px) {
    .footer-content {
      grid-template-columns: repeat(var(--grid-columns), 1fr);
    }

    /* Single item centered */
    .footer-content[style*='--grid-columns: 1'] {
      justify-items: center;
    }

    .footer-content--isolated-grid-item-desktop > :last-child {
      grid-column: 1 / -1;
    }
  }

  /* --- Habits footer polish: single hero-style card (mirrors Image banner / hero) --- */

/* =========================================================
   EASILY ADJUSTABLE KNOBS
   - Card corner radius:  --footer-card-radius (hero uses ~20px)
   - Outer inset:         --footer-card-inset (green page bg shows around)
   - Banner heights:      --footer-card-minh / --footer-card-minh-mobile
   - Content max width:   --footer-card-content-max
   - Email pill width:    --footer-pill-max
   - Nav link gap:        --footer-nav-gap
   ========================================================= */
.footer-content {
  --footer-card-radius: 24px;            /* matches the hero's border_radius (24) */
  --footer-card-inset: 12px;             /* matches the hero's section_margin (12); green shows around */
  --footer-card-minh: 560px;             /* desktop reads as a banner (hero "large") */
  --footer-card-minh-mobile: 440px;
  --footer-card-content-max: 36rem;      /* keep centered stack from sprawling */
  --footer-pill-max: 26rem;              /* email pill width when centered */
  --footer-nav-gap: 28px;                /* horizontal gap between nav links */
}

/* -------- The single hero card = the group-block grid child -------- */
/* With one top-level block, .group-block IS the direct grid child (no wrapper). */
.footer-content > :first-child {
  position: relative;                 /* base.css sets this; explicit for safety */
  width: 100%;
  min-height: var(--footer-card-minh);
  border-radius: var(--footer-card-radius);
  overflow: hidden;                   /* clip image + overlay to rounded corners */
  background-color: #024b40;          /* store green fallback before image loads */
  /* inset from the page edges so the green band shows around (screen-in-screen) */
  margin-inline: var(--footer-card-inset);
  margin-block-end: var(--footer-card-inset);
}

/* Background media wrapper fills the card behind the centered content */
.footer-content > :first-child .group-block__media-wrapper {
  position: absolute;
  inset: 0;
}

/* Background image fills the card, cover (real Horizon hooks) */
.footer-content > :first-child .background-image-container {
  border-radius: var(--footer-card-radius);
}
.footer-content > :first-child .background-image-container img {
  object-fit: cover;
  object-position: center center;
  width: 100%;
  height: 100%;
}

/* Dark overlay scrim for legibility; round its corners to match the card */
.footer-content > :first-child .overlay {
  border-radius: var(--footer-card-radius);
}

/* -------- Centered content stack, nav pushed to the bottom -------- */
.footer-content > :first-child .group-block-content {
  position: relative;                 /* sits above media + overlay */
  z-index: 2;
  display: flex;
  flex-direction: column;
  align-items: center;                /* horizontal center */
  justify-content: center;            /* vertical center */
  text-align: center;
  min-height: var(--footer-card-minh);
  width: 100%;
  padding-block: clamp(2.5rem, 6vw, 4rem);
  padding-inline: clamp(1.25rem, 5vw, 3rem);
}

/* Vertically CENTER the main content (logo -> email): an auto top-margin on the
   first child pairs with the nav's auto top-margin below, so the free space
   splits evenly above the content and below it — content centered, nav at the
   bottom. Collapses gracefully on short/mobile cards (auto margins go to 0). */
.footer-content > :first-child .group-block-content > :first-child {
  margin-block-start: auto;
}

/* Constrain the inner blocks so the centered stack stays tidy */
.footer-content > :first-child .logo-block,
.footer-content > :first-child .text-block,
.footer-content > :first-child .email-signup-block {
  max-width: var(--footer-card-content-max);
  width: 100%;
}

/* Logo: prominent, centered, crisp (light/inverse asset over the dark overlay) */
.footer-content > :first-child .logo-block__image {
  max-width: 260px;
  height: auto;
  margin-inline: auto;
}

/* White, legible heading + subtext over the photo overlay */
.footer-content > :first-child .group-block-content :is(h1, h2, h3, h4, h5, h6) {
  color: #ffffff;
}
.footer-content > :first-child .group-block-content p {
  color: #ffffff;
  opacity: 0.9;
}

/* -------- Email pill: white field, near-black text, orange button -------- */
.footer-content .email-signup-block {
  margin-inline: auto;
  max-width: var(--footer-pill-max);
}
.footer-content .email-signup__input-group--integrated {
  background: #ffffff;
  border-color: #ffffff;
}
.footer-content .email-signup__input {
  color: #1a1a1a;
  background: transparent;
}
.footer-content .email-signup__input::placeholder { color: #9a9a94; }
.footer-content .email-signup__input-group:focus-within {
  box-shadow: 0 0 0 2px rgba(74, 143, 109, 0.25);
}
/* Integrated "Запиши се" button keeps the scheme's orange primary, pill-matched */
.footer-content .email-signup__button.button { border-radius: 100px; }
.footer-content .email-signup__button.button:hover { opacity: 0.92; }

/* -------- Bottom horizontal nav menu (main-menu links) -------- */
/* Push the menu to the bottom of the centered column. */
.footer-content > :first-child .menu {
  margin-block-start: auto;
  padding-block-start: clamp(1.5rem, 4vw, 2.5rem);
}
/* Turn the vertical list into a centered horizontal row (real menu hooks). */
.footer-content .menu .list-unstyled {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  justify-content: center;
  gap: var(--footer-nav-gap);
}
/* Kill the stacked vertical margin so the row spaces evenly via gap. */
.footer-content .menu .menu__item + .menu__item {
  margin-block-start: 0;
}
/* White links with a calm hover (the <a> has no class — target via .menu__item a). */
.footer-content .menu .menu__item a {
  color: #ffffff;
  text-decoration: none;
}
.footer-content .menu .menu__item a:hover { opacity: 0.8; }

/* Soft, calm interactions (store signature 0.2s) */
.footer-content a,
.footer-content .email-signup__button { transition: opacity 0.2s ease; }

/* -------- Mobile: shorter card, comfortable stack, nav wraps -------- */
@media screen and (max-width: 749px) {
  .footer-content {
    --footer-card-inset: 14px;
    --footer-nav-gap: 18px;
  }
  .footer-content > :first-child {
    min-height: var(--footer-card-minh-mobile);
  }
  .footer-content > :first-child .group-block-content {
    min-height: var(--footer-card-minh-mobile);
  }
  .footer-content .email-signup-block { width: 100%; }
  /* Keep the INTEGRATED email pill a single fitting row on mobile. The theme forces
     input + button to width:100% for its stacked (non-integrated) layout, which makes
     our integrated pill overflow the card and clip on the right. Revert to a fitting row:
     button sizes to its text, input flexes to fill the rest. */
  .footer-content .email-signup__input-group--integrated {
    max-width: 100%;
  }
  .footer-content .email-signup__input-group--integrated .email-signup__input,
  .footer-content .email-signup__button--integrated {
    width: auto;
  }
  .footer-content > :first-child .logo-block__image { max-width: 200px; }
}
{% endstylesheet %}

{% schema %}
{
  "name": "t:names.footer",
  "class": "section-wrapper",
  "blocks": [
    {
      "type": "_divider"
    },
    {
      "type": "@app"
    },
    {
      "type": "button"
    },
    {
      "type": "follow-on-shop"
    },
    {
      "type": "group"
    },
    {
      "type": "icon"
    },
    {
      "type": "image"
    },
    {
      "type": "menu"
    },
    {
      "type": "payment-icons"
    },
    {
      "type": "text"
    },
    {
      "type": "logo"
    },
    {
      "type": "jumbo-text"
    },
    {
      "type": "social-links"
    },
    {
      "type": "email-signup"
    }
  ],
  "enabled_on": {
    "groups": ["footer"]
  },
  "settings": [
    {
      "type": "select",
      "id": "section_width",
      "label": "t:settings.width",
      "options": [
        {
          "value": "page-width",
          "label": "t:options.page"
        },
        {
          "value": "full-width",
          "label": "t:options.full"
        }
      ],
      "default": "page-width"
    },
    {
      "type": "range",
      "id": "gap",
      "label": "t:settings.gap",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 20
    }
  ],
  "presets": [
    {
      "name": "t:names.footer",
      "category": "t:categories.footer",
      "settings": {
        "gap": 20,
        "color_scheme": "scheme-1",
        "padding-block-start": 36,
        "padding-block-end": 36
      },
      "blocks": {
        "newsletter-group": {
          "type": "group",
          "settings": {
            "content_direction": "column",
            "vertical_on_mobile": true,
            "horizontal_alignment": "flex-start",
            "vertical_alignment": "center",
            "gap": 6,
            "width": "fill",
            "inherit_color_scheme": true
          },
          "blocks": {
            "newsletter-heading": {
              "type": "text",
              "settings": {
                "text": "t:html_defaults.join_our_email_list",
                "width": "100%",
                "alignment": "left",
                "type_preset": "h3"
              }
            },
            "newsletter-text": {
              "type": "text",
              "settings": {
                "text": "t:html_defaults.get_exclusive_deals_and_early_access_to_new_products",
                "width": "100%",
                "alignment": "left",
                "type_preset": "rte"
              }
            }
          },
          "block_order": ["newsletter-heading", "newsletter-text"]
        },
        "newsletter-form": {
          "type": "email-signup",
          "settings": {
            "width": "fill"
          }
        }
      },
      "block_order": ["newsletter-group", "newsletter-form"]
    }
  ]
}
{% endschema %}
