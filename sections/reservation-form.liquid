    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#4a8f6d"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "label_color",
      "label": "Label color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "input_background",
      "label": "Input background",
