{%- doc -%}
  Renders the cart summary totals.

  @param {string} [accelerated_checkout_buttons_layout] - { 'vertical' } Forced layout of the additional checkout buttons, instead of relying on platform's layout.
  @param {string} [section_id] - The section ID for cart discount component.
{%- enddoc -%}

<div class="cart-totals">
  {% # We need to keep this node in place to allow morphing to work properly # %}
  <div class="cart-totals__original-container cart-primary-typography">
    {%- if cart.cart_level_discount_applications.size > 0 -%}
      <span class="cart-totals__item cart-totals__original">
        <span class="cart-totals__original-label">{{ 'content.cart_subtotal' | t }}</span>
        <span
          class="cart-totals__original-value cart-secondary-typography"
          data-testid="cart-subtotal-value"
        >
          {{- cart.items_subtotal_price | money -}}
        </span>
      </span>
      <ul
        class="cart-discounts"
        role="list"
        aria-label="{{ 'content.discounts' | t }}"
      >
        {%- for discount in cart.cart_level_discount_applications -%}
          <li class="cart-discounts__item">
            <span class="cart-discounts__label">
              {{- 'icon-discount.svg' | inline_asset_content -}}
              {{ discount.title | escape }}
            </span>
            <span class="cart-discounts__value cart-secondary-typography"
              >-{{ discount.total_allocated_amount | money -}}
            </span>
          </li>
        {%- endfor -%}
      </ul>
    {%- endif -%}
  </div>

  {% if settings.show_cart_note or settings.show_add_discount_code %}
    <div class="cart-actions">
      {% if settings.show_cart_note %}
        <script
          type="module"
          src="{{ 'cart-note.js' | asset_url }}"
        ></script>

        <cart-note style="display: flex;">
          <accordion-custom
            class="cart-note"
            {% if settings.cart_note_open_by_default %}
              open-by-default-on-desktop
              open-by-default-on-mobile
            {% endif %}
          >
            <details
              class="details"
              {% if settings.cart_note_open_by_default %}
                open
              {% endif %}
            >
              <summary class="cart-note__summary">
                <span class="cart-note__label cart-primary-typography">
                  {{ 'content.seller_note' | t }}
                </span>

                <span class="cart-totals__icon">
                  {{- 'icon-plus.svg' | inline_asset_content -}}
                </span>
              </summary>

              <div class="details-content cart-note__inner">
                <label
                  for="cart-note"
                  class="visually-hidden"
                >
                  {{- 'content.seller_note' | t -}}
                </label>
                <textarea
                  form="cart-form"
                  on:input="/updateCartNote"
                  id="cart-note"
                  class="cart-note__instructions"
                  name="note"
                >{{ cart.note }}</textarea>
              </div>
            </details>
          </accordion-custom>
        </cart-note>
      {% endif %}
      {% if settings.show_cart_note and settings.show_add_discount_code %}
        <div class="cart-actions__divider"></div>
      {% endif %}
      {% if settings.show_add_discount_code %}
        {% liquid
          assign discount_codes = cart.cart_level_discount_applications | where: 'type', 'discount_code' | map: 'title'
          for item in cart.items
            for allocation in item.line_level_discount_allocations
              if allocation.discount_application.type == 'discount_code'
                assign discount_codes = item.line_level_discount_allocations | slice: forloop.index0 | map: 'discount_application' | map: 'title' | concat: discount_codes
              endif
            endfor
          endfor

          assign discount_codes = discount_codes | uniq

          # Evaluate the boolean expression for the disclosure state
          if discount_codes.size == 0
            assign disclosure_expanded = false
          else
            assign disclosure_expanded = true
          endif
        %}

        <accordion-custom class="cart-discount">
          <details
            class="details"
            {% if disclosure_expanded %}
              open
            {% endif %}
          >
            <summary class="cart-discount__summary">
              <span class="cart-discount__label cart-primary-typography">{{ 'content.discount' | t }}</span>

              <span class="cart-totals__icon">
                {{- 'icon-plus.svg' | inline_asset_content -}}
              </span>
            </summary>

            <div class="details-content">
              <div id="cart-discount-disclosure">
                <cart-discount-component
                  {% if section_id != blank %}
                    data-section-id="{{ section_id }}"
                  {% endif %}
                >
                  <div class="cart-discount__content">
                    <form
                      on:submit="/applyDiscount"
                      onsubmit="return false;"
                      class="cart-discount__form"
                    >
                      <label
                        for="cart-discount"
                        class="visually-hidden"
                      >
                        {{- 'accessibility.discount' | t -}}
                      </label>
                      <input
                        id="cart-discount"
                        class="cart-discount__input"
                        type="text"
                        name="discount"
                        size="8"
                        placeholder="{{ 'content.discount_code' | t }}"
                        required
                      >
                      <button
                        type="submit"
                        class="button cart-discount__button"
                      >
                        {{ 'actions.apply' | t }}
                      </button>
                    </form>
                  </div>
                  <div
                    class="cart-discount__error hidden"
                    role="alert"
                    ref="cartDiscountError"
                  >
                    <span class="svg-wrapper">
                      {{- 'icon-error.svg' | inline_asset_content -}}
                    </span>
                    <small
                      class="cart-discount__error-text cart-primary-typography hidden"
                      ref="cartDiscountErrorDiscountCode"
                    >
                      {{ 'content.discount_code_error' | t: code: 'test' }}
                    </small>
                    <small
                      class="cart-discount__error-text cart-primary-typography hidden"
                      ref="cartDiscountErrorShipping"
                    >
                      {{ 'content.shipping_discount_error' | t }}
                    </small>
                  </div>
                  <ul class="cart-discount__codes">
                    {% for discount_code in discount_codes %}
                      <li
                        class="cart-discount__pill"
                        data-discount-code="{{ discount_code }}"
                        aria-label="{{ 'accessibility.discount_applied' | t: code: discount_code }}"
                      >
                        <p class="cart-discount__pill-code">
                          {{ discount_code }}
                        </p>
                        <button
                          type="button"
                          on:click="/removeDiscount"
                          class="cart-discount__pill-remove svg-wrapper svg-wrapper--smaller button-unstyled"
                          aria-label="{{ 'actions.remove_discount' | t: code: discount_code }}"
                        >
                          {{- 'icon-filters-close.svg' | inline_asset_content -}}
                        </button>
                      </li>
                    {% endfor %}
                  </ul>
                </cart-discount-component>
              </div>
            </div>
          </details>
        </accordion-custom>
      {% endif %}
    </div>
  {% endif %}

  {%- liquid
    if settings.currency_code_enabled_cart_total
      assign total_price = cart.total_price | money_with_currency
    else
      assign total_price = cart.total_price | money
    endif
  -%}

  <div class="cart-totals__container{% if settings.show_installments %} cart-totals__container--has-installments{% endif %}">
    <span
      class="cart-totals__item cart-totals__total"
      role="status"
    >
      <span class="cart-totals__total-label cart-primary-typography">{{ 'content.cart_estimated_total' | t }}</span>
      <text-component
        ref="cartTotal"
        value="{{ total_price | strip_html }}"
        class="cart-totals__total-value cart-secondary-typography"
        {% comment %} Used by payment_terms web component {% endcomment %}
        data-testid="cart-total-value"
        data-cart-subtotal
      >
        {{ total_price }}
      </text-component>
    </span>
    {% if settings.show_installments %}
      <span class="cart-totals__item cart-totals__installments">
        {% form 'cart', cart %}
          {{ form | payment_terms }}
        {% endform %}
      </span>
    {% endif %}
    <div class="cart-totals__item cart-totals__tax-note cart-primary-typography">
      {% render 'tax-info', has_discounts_enabled: settings.show_add_discount_code %}
    </div>
  </div>
</div>

<div class="cart__ctas">
  <div class="cart__delivery-info" data-cart-delivery-info>
    <p class="cart__delivery-info-title">Въведете информация за доставка за да продължите напред</p>

    <div class="cart__delivery-phone" data-cart-delivery-phone>
      <label class="cart__delivery-info-label" for="cart-delivery-phone">Телефон за доставка *</label>
      <input
        type="tel"
        id="cart-delivery-phone"
        class="cart__delivery-info-input"
        name="attributes[Delivery phone]"
        form="cart-form"
        inputmode="tel"
        autocomplete="tel"
        pattern="^(\+359|0)[0-9]{9}$"
        placeholder="+359..."
        value="{{ cart.attributes['Delivery phone'] | escape }}"
        required
      >
      <small class="cart__delivery-info-hint">Необходим за доставка с Wolt — ще получите SMS с проследяване</small>
      <div class="cart__delivery-phone-error cart__delivery-info-error" role="alert" aria-live="polite"></div>
    </div>

    <div class="cart__delivery-address" data-cart-delivery-address>
      <label class="cart__delivery-info-label" for="cart-delivery-address">Адрес за доставка *</label>
      <input
        type="text"
        id="cart-delivery-address"
        class="cart__delivery-info-input"
        name="attributes[Delivery address]"
        form="cart-form"
        autocomplete="street-address"
        placeholder="ул. Преслав 5, ап. 3"
        value="{{ cart.attributes['Delivery address'] | escape }}"
        required
      >

      <div class="cart__delivery-info-row">
        <div class="cart__delivery-info-col">
          <label class="cart__delivery-info-label" for="cart-delivery-city">Град *</label>
          <input
            type="text"
            id="cart-delivery-city"
            class="cart__delivery-info-input"
            name="attributes[Delivery city]"
            form="cart-form"
            autocomplete="address-level2"
            placeholder="Варна"
            value="{{ cart.attributes['Delivery city'] | escape }}"
            required
          >
        </div>
        <div class="cart__delivery-info-col cart__delivery-info-col--zip">
          <label class="cart__delivery-info-label" for="cart-delivery-zip">Пощенски код *</label>
          <input
            type="text"
            id="cart-delivery-zip"
            class="cart__delivery-info-input"
            name="attributes[Delivery zip]"
            form="cart-form"
            inputmode="numeric"
            autocomplete="postal-code"
            pattern="^[0-9]{4}$"
            maxlength="4"
            placeholder="9000"
            value="{{ cart.attributes['Delivery zip'] | escape }}"
            required
          >
        </div>
      </div>

      <small class="cart__delivery-info-hint">Необходимо за доставка с Wolt — куриерът ще бъде изпратен до този адрес</small>
      <div class="cart__delivery-address-error cart__delivery-info-error" role="alert" aria-live="polite"></div>
    </div>
  </div>
  <button
    type="submit"
    id="checkout"
    class="cart__checkout-button button"
    name="checkout"
    {% if cart == empty %}
      disabled
    {% endif %}
    form="cart-form"
  >
    <span class="button-text">
      {{ 'content.checkout' | t }}
    </span>
  </button>

  {% if additional_checkout_buttons and settings.show_accelerated_checkout_buttons %}
    <div
      class="
        additional-checkout-buttons
        {% if accelerated_checkout_buttons_layout == 'vertical' %}additional-checkout-buttons--vertical{% endif %}
      "
    >
      {{ content_for_additional_checkout_buttons }}
    </div>
  {% endif %}
</div>

{% stylesheet %}
  .cart-actions {
    display: flex;
    flex-direction: column;
    gap: 0;
    border-block: 1px solid var(--color-border);
    padding-block: 0;
    margin-block-start: var(--margin-3xs);
  }

  .cart-actions__divider {
    border-block-start: 1px solid var(--color-border);
  }

  .cart-totals:not(:has(.cart-actions)) {
    margin-block-start: var(--margin-3xs);
    border-block-start: 1px solid var(--color-border);
    padding-block-start: var(--margin-xl);
  }

  .cart-totals__item {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .cart-totals__tax-note {
    color: rgb(var(--color-foreground-rgb) / var(--opacity-subdued-text));
  }

  .cart-totals__tax-note small {
    font-size: var(--font-size--2xs);
  }

  .cart-discounts {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .cart-discounts__item {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .cart-discounts__label {
    display: flex;
    align-items: center;
    gap: var(--gap-2xs);
  }

  .cart-discounts__label svg {
    width: var(--icon-size-sm);
    height: var(--icon-size-sm);
    display: inline-block;
  }

  .cart-totals__original-container,
  .cart-totals__container {
    display: flex;
    flex-direction: column;
  }

  .cart-totals__container {
    row-gap: var(--gap-2xs);

    &.cart-totals__container--has-installments {
      row-gap: var(--gap-xs);
    }
  }

  .cart-totals__original-container:empty {
    display: none;
  }

  .cart-totals {
    display: flex;
    flex-direction: column;
    gap: var(--gap-xl);
    width: 100%;
    border-block-start: none;

    &:has(> :first-child:not(.cart-totals__original-container, .cart-totals__container)) {
      padding-block-start: 0;
      border-block-start: none;
    }

    @media screen and (min-width: 750px) {
      padding-block-start: 0;
    }
  }

  .cart-totals__original-container,
  .cart-totals__original-container * {
    font-size: var(--cart-font-size--sm);
  }

  .cart-totals__total {
    align-items: baseline;
    font-weight: var(--font-weight-bold);
  }

  .cart-totals__total-label {
    font-size: var(--cart-font-size--sm);
  }

  .cart-totals__total-value {
    font-size: var(--cart-font-size--xl);

    @media screen and (max-width: 749px) {
      font-size: var(--font-size--lg);
    }
  }

  .cart-totals__installments {
    color: var(--color-foreground);
    font-size: var(--font-size--2xs);
  }

  .cart-note {
    width: 100%;
  }

  @starting-style {
    .cart-note[open-by-default-on-desktop][open-by-default-on-mobile] .details-content {
      block-size: auto;
      opacity: 1;
      overflow-y: visible;
    }
  }

  .cart-note__inner {
    padding-block: var(--padding-2xs) var(--padding-sm);
  }

  .cart-note__summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .cart-note__summary:hover {
    color: rgb(var(--color-foreground-rgb) / var(--opacity-subdued-text));
  }

  .cart-note__label {
    display: flex;
    align-items: flex-start;
    gap: var(--gap-2xs);
    font-size: var(--font-size--2xs);
    font-weight: 500;
  }

  .cart-note__instructions {
    color: var(--color-input-text);
    background-color: var(--color-input-background);
    border-width: var(--style-border-width-inputs);
    border-color: var(--color-input-border);
    transition: box-shadow var(--animation-speed) ease;
    box-shadow: var(--input-box-shadow);
    min-height: 5.5rem;
    min-width: 100%;
    max-width: 100%;
    font-size: var(--font-size--sm);
    padding: max(4px, calc(var(--style-border-radius-inputs) * (1 - cos(45deg))));
  }

  .cart-totals__icon {
    height: var(--icon-size-xs);
    width: var(--icon-size-xs);
    margin: 0;
  }

  .cart__ctas {
    width: 100%;
    display: grid;
    gap: var(--checkout-button-gap);
    grid-auto-flow: row;
    grid-template-columns: 1fr;
  }

  .cart__ctas .cart__checkout-button {
    width: 100%;
    height: clamp(25px, var(--height-buy-buttons), 55px);
    padding-inline: var(--padding-4xl);
  }

  .cart__delivery-info {
    display: flex;
    flex-direction: column;
    gap: var(--gap-md, 10px);
  }

  .cart__delivery-info-title {
    margin: 0 0 var(--margin-3xs, 4px);
    font-size: var(--font-size--sm);
    font-weight: var(--font-weight-bold);
    color: var(--color-foreground);
    line-height: 1.35;
  }

  .cart__delivery-phone,
  .cart__delivery-address {
    display: flex;
    flex-direction: column;
    gap: var(--gap-3xs, 4px);
  }

  .cart__delivery-info-label {
    font-size: var(--font-size--2xs);
    font-weight: 500;
    color: var(--color-foreground);
  }

  .cart__delivery-info-input {
    width: 100%;
    color: var(--color-input-text);
    background-color: var(--color-input-background);
    border-width: var(--style-border-width-inputs);
    border-color: var(--color-input-border);
    border-style: solid;
    border-radius: var(--style-border-radius-inputs);
    padding: var(--padding-sm) var(--padding-md);
    font-size: var(--font-size--sm);
    transition: box-shadow var(--animation-speed) ease, border-color var(--animation-speed) ease;
    box-shadow: var(--input-box-shadow);
    box-sizing: border-box;
  }

  .cart__delivery-info-input::placeholder {
    color: rgb(var(--color-input-text-rgb) / var(--opacity-subdued-text));
  }

  .cart__delivery-phone.is-invalid .cart__delivery-info-input,
  .cart__delivery-info-input.is-invalid {
    border-color: #c0392b;
    box-shadow: 0 0 0 3px rgba(192, 57, 43, 0.12);
  }

  .cart__delivery-info-hint {
    font-size: var(--font-size--2xs);
    color: rgb(var(--color-foreground-rgb) / var(--opacity-subdued-text));
    line-height: 1.4;
  }

  .cart__delivery-info-error {
    display: none;
    font-size: var(--font-size--2xs);
    color: #c0392b;
    margin-top: var(--margin-3xs, 2px);
  }

  .cart__delivery-phone.is-invalid > .cart__delivery-info-error,
  .cart__delivery-address.is-invalid > .cart__delivery-info-error {
    display: block;
  }

  .cart__delivery-info-row {
    display: flex;
    gap: var(--gap-sm, 10px);
    margin-top: var(--margin-3xs, 4px);
  }

  .cart__delivery-info-col {
    display: flex;
    flex-direction: column;
    gap: var(--gap-3xs, 4px);
    flex: 2 1 0;
    min-width: 0;
  }

  .cart__delivery-info-col--zip {
    flex: 1 1 0;
  }

  @media screen and (max-width: 380px) {
    .cart__delivery-info-row {
      flex-direction: column;
    }
  }

  .cart-drawer__summary .cart-totals:not(:has(.cart-totals__original-container:empty)) {
    border-block-start: var(--style-border-width) solid var(--color-border);
    padding-block-start: var(--padding-2xl);
  }

  .cart-drawer__summary .cart-note {
    @media screen and (min-width: 750px) {
      margin-block-start: var(--margin-3xs);
    }
  }

  .cart-discount__input {
    background-color: var(--color-input-background);
    color: var(--color-input-text);
    border-width: var(--style-border-width-inputs);
    border-color: var(--color-input-border);
    border-style: solid;
    border-radius: var(--style-border-radius-inputs);
    padding: var(--padding-sm) var(--padding-md);
    height: 100%;
    flex-grow: 1;
    min-width: 0;
    font-size: var(--font-size--sm);
  }

  .cart-discount__input::placeholder {
    color: rgb(var(--color-input-text-rgb) / var(--opacity-subdued-text));
  }

  .cart-discount__pill-code {
    overflow: hidden;
    max-width: 100px;
    text-overflow: ellipsis;
    white-space: nowrap;
    margin: 0;
  }

  .cart-discount {
    width: 100%;
  }

  .cart-discount__codes {
    display: none;
    gap: var(--padding-xs);
    flex-wrap: wrap;
    list-style: none;
    padding-inline: 0;
    margin: 0;
  }

  .cart-discount__codes:has(.cart-discount__pill) {
    display: flex;
  }

  .cart-discount__button {
    height: 100%;
  }

  .cart-discount__content {
    height: calc(var(--button-size) + var(--padding-2xs) + var(--padding-sm));
  }

  .cart-discount__pill {
    display: flex;
    color: var(--color-foreground);
    gap: var(--padding-xs);
    align-items: center;
    padding: var(--padding-xs) var(--padding-sm);
    border-radius: var(--style-border-radius-pills);
    background-color: var(--color-input-background);
    text-transform: uppercase;
  }

  .cart-discount__form {
    display: flex;
    gap: var(--padding-md);
    align-items: center;
    height: 100%;
    padding-block: var(--padding-2xs) var(--padding-sm);
  }

  :is(.cart-discount__pill-remove, .cart-discount__pill-remove:hover) {
    --close-icon-opacity: 0.4;

    color: var(--color-foreground);
    background-color: transparent;
    pointer-events: all;
    cursor: pointer;
    height: 100%;
  }

  .cart-discount__error {
    display: flex;
    align-items: center;
    width: 100%;
    padding-block: var(--padding-2xs) var(--padding-sm);
  }

  .cart-discount__error .svg-wrapper {
    flex-shrink: 0;
    width: var(--icon-size-xs);
    height: var(--icon-size-xs);
    margin-inline: var(--margin-3xs) var(--margin-xs);
  }

  .cart-discount__error-text {
    margin-block-start: var(--margin-3xs);
  }

  .cart-discount__summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .cart-discount__summary:hover {
    color: rgb(var(--color-foreground-rgb) / var(--opacity-subdued-text));
  }

  .cart-discount__label {
    display: flex;
    align-items: flex-start;
    gap: var(--gap-2xs);
    font-size: var(--font-size--2xs);
    font-weight: 500;
  }

  @media screen and (min-width: 750px) {
    .cart-summary--extend {
      height: 100%;
    }
  }
{% endstylesheet %}

<script>
  (function () {
    if (window.__cartDeliveryPhoneWired) return;
    window.__cartDeliveryPhoneWired = true;

    var PHONE_REGEX = /^\+359[0-9]{9}$/;
    var STORAGE_KEY = 'habits_delivery_phone';

    function normalizePhone(val) {
      var v = (val || '').trim().replace(/\s+/g, '');
      if (v.charAt(0) === '0') return '+359' + v.substring(1);
      return v;
    }

    function validate(val) {
      var normalized = normalizePhone(val);
      if (!normalized) return { ok: false, message: 'Моля въведете телефон за доставка' };
      if (!PHONE_REGEX.test(normalized)) {
        return { ok: false, message: 'Невалиден телефонен номер (формат: +359XXXXXXXXX)' };
      }
      return { ok: true, normalized: normalized };
    }

    function saveToCart(phone) {
      return fetch('/cart/update.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
        body: JSON.stringify({ attributes: { 'Delivery phone': phone } })
      }).then(function (r) {
        if (!r.ok) throw new Error('cart update failed');
        return r.json();
      });
    }

    var ADDRESS_KEYS = {
      address: 'habits_delivery_address',
      city: 'habits_delivery_city',
      zip: 'habits_delivery_zip'
    };
    var ZIP_REGEX = /^[0-9]{4}$/;

    function validateAddress(addrInput, cityInput, zipInput) {
      var a = (addrInput.value || '').trim();
      var c = (cityInput.value || '').trim();
      var z = (zipInput.value || '').trim();
      if (!a || a.length < 3) return { ok: false, message: 'Моля въведете адрес', focus: addrInput };
      if (!c || c.length < 2) return { ok: false, message: 'Моля въведете град', focus: cityInput };
      if (!ZIP_REGEX.test(z)) return { ok: false, message: 'Невалиден пощенски код (4 цифри)', focus: zipInput };
      return { ok: true, address: a, city: c, zip: z };
    }

    function saveAddressToCart(address, city, zip) {
      var attrs = {};
      if (address) attrs['Delivery address'] = address;
      if (city) attrs['Delivery city'] = city;
      if (zip) attrs['Delivery zip'] = zip;
      if (Object.keys(attrs).length === 0) return Promise.resolve(null);
      return fetch('/cart/update.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
        body: JSON.stringify({ attributes: attrs })
      }).then(function (r) {
        if (!r.ok) throw new Error('cart update failed');
        return r.json();
      });
    }

    function init() {
      var input = document.getElementById('cart-delivery-phone');
      if (!input) return;
      var wrapper = input.closest('.cart__delivery-phone');
      var errorEl = wrapper ? wrapper.querySelector('.cart__delivery-phone-error') : null;

      try {
        var saved = window.localStorage && window.localStorage.getItem(STORAGE_KEY);
        if (saved && !input.value) input.value = saved;
      } catch (e) { /* ignore */ }

      function setState(result) {
        if (!wrapper) return;
        if (result.ok) {
          wrapper.classList.remove('is-invalid');
          if (errorEl) errorEl.textContent = '';
        } else {
          wrapper.classList.add('is-invalid');
          if (errorEl) errorEl.textContent = result.message;
        }
      }

      // Save on blur: validate, normalize, persist to cart.attributes immediately
      input.addEventListener('blur', function () {
        var result = validate(input.value);
        setState(result);
        if (!result.ok) return;
        input.value = result.normalized;
        try {
          if (window.localStorage) window.localStorage.setItem(STORAGE_KEY, result.normalized);
        } catch (err) { /* ignore */ }
        saveToCart(result.normalized).catch(function (err) {
          console.error('[Habits] phone save failed:', err);
        });
      });

      input.addEventListener('input', function () {
        if (wrapper && wrapper.classList.contains('is-invalid')) setState(validate(input.value));
      });

      // ---- Address / city / zip ----
      var addrInput = document.getElementById('cart-delivery-address');
      var cityInput = document.getElementById('cart-delivery-city');
      var zipInput = document.getElementById('cart-delivery-zip');
      var addrWrapper = addrInput ? addrInput.closest('.cart__delivery-address') : null;
      var addrError = addrWrapper ? addrWrapper.querySelector('.cart__delivery-address-error') : null;
      var addressInputs = [addrInput, cityInput, zipInput].filter(Boolean);

      try {
        if (window.localStorage) {
          if (addrInput && !addrInput.value) addrInput.value = window.localStorage.getItem(ADDRESS_KEYS.address) || '';
          if (cityInput && !cityInput.value) cityInput.value = window.localStorage.getItem(ADDRESS_KEYS.city) || '';
          if (zipInput && !zipInput.value) zipInput.value = window.localStorage.getItem(ADDRESS_KEYS.zip) || '';
        }
      } catch (e) { /* ignore */ }

      function setAddressState(result) {
        addressInputs.forEach(function (el) { el.classList.remove('is-invalid'); });
        if (!addrWrapper) return;
        if (result.ok) {
          addrWrapper.classList.remove('is-invalid');
          if (addrError) addrError.textContent = '';
        } else {
          addrWrapper.classList.add('is-invalid');
          if (addrError) addrError.textContent = result.message;
          if (result.focus) result.focus.classList.add('is-invalid');
        }
      }

      if (addressInputs.length === 3) {
        addressInputs.forEach(function (el) {
          el.addEventListener('blur', function () {
            el.value = (el.value || '').trim();
            var result = validateAddress(addrInput, cityInput, zipInput);
            setAddressState(result);
            try {
              if (window.localStorage) {
                if (addrInput.value) window.localStorage.setItem(ADDRESS_KEYS.address, addrInput.value);
                if (cityInput.value) window.localStorage.setItem(ADDRESS_KEYS.city, cityInput.value);
                if (zipInput.value) window.localStorage.setItem(ADDRESS_KEYS.zip, zipInput.value);
              }
            } catch (err) { /* ignore */ }
            saveAddressToCart(addrInput.value, cityInput.value, zipInput.value).catch(function (err) {
              console.error('[Habits] address save failed:', err);
            });
          });

          el.addEventListener('input', function () {
            if (addrWrapper && addrWrapper.classList.contains('is-invalid')) {
              setAddressState(validateAddress(addrInput, cityInput, zipInput));
            }
          });
        });

        // Keep zip digit-only up to 4 chars
        zipInput.addEventListener('input', function () {
          var digits = zipInput.value.replace(/\D+/g, '').slice(0, 4);
          if (digits !== zipInput.value) zipInput.value = digits;
        });
      }

      // Block checkout button with capture phase (runs before theme handlers)
      var checkoutBtn = document.querySelector('[name="checkout"]');
      if (checkoutBtn) {
        checkoutBtn.addEventListener('click', function (e) {
          var phoneResult = validate(input.value);
          if (!phoneResult.ok) {
            e.preventDefault();
            e.stopPropagation();
            setState(phoneResult);
            input.focus();
            return;
          }
          input.value = phoneResult.normalized;
          try {
            if (window.localStorage) window.localStorage.setItem(STORAGE_KEY, phoneResult.normalized);
          } catch (err) { /* ignore */ }
          saveToCart(phoneResult.normalized).catch(function (err) {
            console.error('[Habits] phone save failed:', err);
          });

          if (addressInputs.length === 3) {
            var addrResult = validateAddress(addrInput, cityInput, zipInput);
            if (!addrResult.ok) {
              e.preventDefault();
              e.stopPropagation();
              setAddressState(addrResult);
              if (addrResult.focus) addrResult.focus.focus();
              return;
            }
            setAddressState(addrResult);
            try {
              if (window.localStorage) {
                window.localStorage.setItem(ADDRESS_KEYS.address, addrResult.address);
                window.localStorage.setItem(ADDRESS_KEYS.city, addrResult.city);
                window.localStorage.setItem(ADDRESS_KEYS.zip, addrResult.zip);
              }
            } catch (err) { /* ignore */ }
            saveAddressToCart(addrResult.address, addrResult.city, addrResult.zip).catch(function (err) {
              console.error('[Habits] address save failed:', err);
            });
          }
        }, true);
      }

      // Hydrate all delivery fields from the cart so a reopened cart reflects real server state
      fetch('/cart.js', { headers: { 'Accept': 'application/json' } })
        .then(function (r) { return r.ok ? r.json() : null; })
        .then(function (cart) {
          if (!cart || !cart.attributes) return;
          var attrs = cart.attributes;
          if (attrs['Delivery phone'] && !input.value) input.value = attrs['Delivery phone'];
          if (addrInput && attrs['Delivery address'] && !addrInput.value) addrInput.value = attrs['Delivery address'];
          if (cityInput && attrs['Delivery city'] && !cityInput.value) cityInput.value = attrs['Delivery city'];
          if (zipInput && attrs['Delivery zip'] && !zipInput.value) zipInput.value = attrs['Delivery zip'];
        })
        .catch(function () { /* ignore */ });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }
  })();
</script>
