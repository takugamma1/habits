{%- doc -%}
  Single-page upsell modal. Shows selected product preview on top,
  addon tiles below, and two action buttons at the bottom.
  JS handles selection + batch add-to-cart.
  @param {object} upsell_collection - Shopify collection for addons
  @param {object} downsell_collection - Shopify collection for extra addons (merged into single list)
  @param {string} upsell_title - Heading for addons
  @param {number} addon_grid_cols - Number of columns for addon grid (default 3)
{%- enddoc -%}

<div class="mp-upsell-overlay" id="mp-upsell-overlay"></div>
<div class="mp-upsell" id="mp-upsell" aria-hidden="true" role="dialog" aria-label="Add extras">
  {%- comment -%} Close button {%- endcomment -%}
  <button type="button" class="mp-upsell__close" id="mp-upsell-close" aria-label="Close">
    <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M5 5l10 10M15 5L5 15" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
  </button>

  {%- comment -%} Selected product preview (populated by JS) {%- endcomment -%}
  <div class="mp-upsell__preview" id="mp-upsell-preview">
    <img class="mp-upsell__preview-img" id="mp-upsell-preview-img" src="" alt="" width="56" height="56">
    <div class="mp-upsell__preview-info">
      <span class="mp-upsell__preview-name" id="mp-upsell-preview-name"></span>
      <span class="mp-upsell__preview-price" id="mp-upsell-preview-price"></span>
    </div>
  </div>

  {%- comment -%} Single page: all addons {%- endcomment -%}
  <div class="mp-upsell__body">
    <h3 class="mp-upsell__title">{{ upsell_title | default: 'Добави към поръчката' }}</h3>
    <div class="mp-upsell__grid" id="mp-upsell-list-1" style="--mp-addon-cols: {{ addon_grid_cols | default: 3 }};">
      {%- comment -%} Upsell products {%- endcomment -%}
      {% if upsell_collection and upsell_collection.products.size > 0 %}
        {% for product in upsell_collection.products %}
          {%- assign variant = product.selected_or_first_available_variant | default: product.first_available_variant -%}
          <div
            class="mp-addon-tile"
            data-variant-id="{{ variant.id }}"
            data-product-id="{{ product.id }}"
            data-product-title="{{ product.title | escape }}"
            data-product-price="{{ variant.price | money }}"
            data-product-price-raw="{{ variant.price }}"
            data-product-image="{{ product.featured_image | image_url: width: 600 }}"
            data-product-description="{{ product.description | strip_html | escape }}"
          >
            <div class="mp-addon-tile__img-wrap">
              {% if product.featured_image %}
                {{ product.featured_image | image_url: width: 300 | image_tag: loading: 'lazy', class: 'mp-addon-tile__img' }}
              {% else %}
                <div class="mp-addon-tile__placeholder">
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
                </div>
              {% endif %}
              <span class="mp-addon-tile__check-icon" aria-hidden="true">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3.5 8.5L6.5 11.5L12.5 4.5" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </span>
            </div>
            <span class="mp-addon-tile__name">{{ product.title }}</span>
            <span class="mp-addon-tile__price">{{ variant.price | money }}</span>
            <input
              type="checkbox"
              class="mp-upsell__check mp-addon-tile__input"
              name="upsell[]"
              value="{{ variant.id }}"
            >
          </div>
        {% endfor %}
      {% endif %}

      {%- comment -%} Downsell products (merged into same grid) {%- endcomment -%}
      {% if downsell_collection and downsell_collection.products.size > 0 %}
        {% for product in downsell_collection.products %}
          {%- comment -%} Skip products already shown from upsell collection {%- endcomment -%}
          {%- assign already_shown = false -%}
          {% if upsell_collection %}
            {% for up_product in upsell_collection.products %}
              {% if up_product.id == product.id %}
                {%- assign already_shown = true -%}
              {% endif %}
            {% endfor %}
          {% endif %}
          {% unless already_shown %}
            {%- assign variant = product.selected_or_first_available_variant | default: product.first_available_variant -%}
            <div
              class="mp-addon-tile"
              data-variant-id="{{ variant.id }}"
              data-product-id="{{ product.id }}"
              data-product-title="{{ product.title | escape }}"
              data-product-price="{{ variant.price | money }}"
              data-product-price-raw="{{ variant.price }}"
              data-product-image="{{ product.featured_image | image_url: width: 600 }}"
              data-product-description="{{ product.description | strip_html | escape }}"
            >
              <div class="mp-addon-tile__img-wrap">
                {% if product.featured_image %}
                  {{ product.featured_image | image_url: width: 300 | image_tag: loading: 'lazy', class: 'mp-addon-tile__img' }}
                {% else %}
                  <div class="mp-addon-tile__placeholder">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
                  </div>
                {% endif %}
                <span class="mp-addon-tile__check-icon" aria-hidden="true">
                  <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3.5 8.5L6.5 11.5L12.5 4.5" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </span>
              </div>
              <span class="mp-addon-tile__name">{{ product.title }}</span>
              <span class="mp-addon-tile__price">{{ variant.price | money }}</span>
              <input
                type="checkbox"
                class="mp-upsell__check mp-addon-tile__input"
                name="upsell[]"
                value="{{ variant.id }}"
              >
            </div>
          {% endunless %}
        {% endfor %}
      {% endif %}

      {% if upsell_collection.products.size == 0 and downsell_collection.products.size == 0 %}
        <p class="mp-upsell__empty">No extras available</p>
      {% endif %}
    </div>
  </div>

  {%- comment -%} Action buttons {%- endcomment -%}
  <div class="mp-upsell__actions">
    <button type="button" class="mp-upsell__skip" data-action="skip-all">Не искам добавка</button>
    <button type="button" class="mp-upsell__next mp-upsell__next--add" data-action="add">Добави в количката</button>
  </div>
</div>

{%- comment -%} ═══════════════════════════════════
  PRODUCT DETAIL POPUP (opens on top of upsell modal)
═══════════════════════════════════ {%- endcomment -%}
<div class="mp-product-popup-overlay" id="mp-product-popup-overlay"></div>
<div class="mp-product-popup" id="mp-product-popup" aria-hidden="true" role="dialog" aria-label="Product details">
  <button type="button" class="mp-product-popup__back" id="mp-product-popup-back" aria-label="Back">
    <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M13 4L7 10l6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
  </button>
  <div class="mp-product-popup__body" id="mp-product-popup-body">
    <div class="mp-product-popup__img-wrap" id="mp-product-popup-img-wrap"></div>
    <div class="mp-product-popup__info">
      <h3 class="mp-product-popup__title" id="mp-product-popup-title"></h3>
      <span class="mp-product-popup__price" id="mp-product-popup-price"></span>
      <p class="mp-product-popup__desc" id="mp-product-popup-desc"></p>
      <button type="button" class="mp-product-popup__add-btn" id="mp-product-popup-add">
        <svg width="16" height="16" viewBox="0 0 18 18" fill="none"><path d="M9 3v12M3 9h12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
        Добави
      </button>
    </div>
  </div>
</div>
