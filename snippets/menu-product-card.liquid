{%- doc -%}
  Renders a menu product card with dark background, image, title, description, price, and + button.
  @param {object} product - The product object
  @param {string} collection_title - The collection/category name
  @param {string} card_bg - Card background color
  @param {string} card_radius - Card border radius in px
  @param {string} button_color - Plus button background
  @param {string} button_text_color - Plus button icon color
{%- enddoc -%}

{%- liquid
  assign variant = product.selected_or_first_available_variant | default: product.first_available_variant
  assign image = product.featured_image
-%}

<div
  class="mp-card"
  data-product-id="{{ product.id }}"
  data-variant-id="{{ variant.id }}"
  data-product-title="{{ product.title | escape }}"
  data-product-price="{{ variant.price | money }}"
  data-product-image="{{ image | image_url: width: 200 }}"
  style="
    --mp-card-bg: {{ card_bg | default: '#1a1a1a' }};
    --mp-card-radius: {{ card_radius | default: 16 }}px;
    --mp-card-btn: {{ button_color | default: '#ffffff' }};
    --mp-card-btn-text: {{ button_text_color | default: '#1a1a1a' }};
  "
>
  {%- comment -%} Image area {%- endcomment -%}
  <div class="mp-card__media">
    {% if image %}
      {{
        image
        | image_url: width: 800
        | image_tag:
          loading: 'lazy',
          sizes: '(max-width: 749px) 45vw, 22vw',
          widths: '200, 300, 400, 600, 800',
          class: 'mp-card__img'
      }}
    {% else %}
      <div class="mp-card__placeholder">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" width="48" height="48"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
      </div>
    {% endif %}

    {%- comment -%} Plus button {%- endcomment -%}
    <button
      type="button"
      class="mp-card__add"
      aria-label="{{ 'actions.add_to_cart' | t | default: 'Add to cart' }}"
      data-variant-id="{{ variant.id }}"
      data-product-id="{{ product.id }}"
    >
      <svg width="18" height="18" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M9 3v12M3 9h12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
      </svg>
    </button>
  </div>

  {%- comment -%} Info area {%- endcomment -%}
  <div class="mp-card__info">
    <h3 class="mp-card__title">{{ product.title }}</h3>
    {% if product.description != blank %}
      <p class="mp-card__desc">{{ product.description | strip_html | truncate: 60 }}</p>
    {% endif %}
    <span class="mp-card__price">{{ variant.price | money }}</span>
  </div>
</div>
