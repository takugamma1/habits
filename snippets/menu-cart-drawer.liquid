{%- doc -%}
  Menu page cart drawer: mobile bottom sheet + desktop side drawer.
  Desktop cart button is rendered inline in the section (not here).
  @param {string} cart_badge_bg - Badge/drawer accent color
  @param {string} cart_cta_text - CTA button text
  @param {string} cart_cta_color - CTA button background color
{%- enddoc -%}

{%- comment -%} ═══ Desktop side drawer ═══ {%- endcomment -%}
<style>.mp-drawer-overlay,.mp-drawer{position:fixed;visibility:hidden}.mp-drawer-overlay.is-open,.mp-drawer.is-open{visibility:visible}</style>
<div class="mp-drawer-overlay" id="mp-drawer-overlay"></div>
<div class="mp-drawer" id="mp-drawer-desktop" aria-hidden="true">
  <div class="mp-drawer__header">
    <h3 class="mp-drawer__title">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" style="margin-right:8px;vertical-align:middle;">
        <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4zM3 6h18"/>
        <path d="M16 10a4 4 0 01-8 0"/>
      </svg>
      Кошница
      <span class="mp-drawer__count" id="mp-drawer-count">(0)</span>
    </h3>
    <button type="button" class="mp-drawer__close" id="mp-drawer-close" aria-label="Close">
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M5 5l10 10M15 5L5 15" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
    </button>
  </div>
  <div class="mp-drawer__body" id="mp-drawer-body">
    <div class="mp-drawer__empty" id="mp-drawer-empty">
      <p>Кошницата е празна</p>
    </div>
    <div class="mp-drawer__items" id="mp-drawer-items"></div>
  </div>
  <div class="mp-drawer__footer" id="mp-drawer-footer">
    <div class="mp-drawer__subtotal">
      <span>Общо</span>
      <span id="mp-drawer-subtotal">0,00 лв.</span>
    </div>
    <div class="mp-delivery-info" data-mp-delivery-scope="drawer">
      <p class="mp-delivery-info__title">Въведете информация за доставка за да продължите напред</p>

      <div class="mp-phone-field" data-mp-phone-scope="drawer">
        <label class="mp-delivery-info__label" for="mp-drawer-phone">Телефон за доставка *</label>
        <input
          type="tel"
          id="mp-drawer-phone"
          class="mp-delivery-info__input"
          name="attributes[Delivery phone]"
          inputmode="tel"
          autocomplete="tel"
          pattern="^(\+359|0)[0-9]{9}$"
          placeholder="+359..."
          required
        >
        <small class="mp-delivery-info__hint">Необходим за доставка с Wolt — ще получите SMS с проследяване</small>
        <div class="mp-delivery-info__error" id="mp-drawer-phone-error" role="alert" aria-live="polite"></div>
      </div>

      <div class="mp-address-field" data-mp-address-scope="drawer">
        <label class="mp-delivery-info__label" for="mp-drawer-address">Адрес за доставка *</label>
        <input
          type="text"
          id="mp-drawer-address"
          class="mp-delivery-info__input"
          name="attributes[Delivery address]"
          autocomplete="street-address"
          placeholder="ул. Преслав 5, ап. 3"
          required
        >

        <div class="mp-delivery-info__row">
          <div class="mp-delivery-info__col">
            <label class="mp-delivery-info__label" for="mp-drawer-city">Град *</label>
            <input
              type="text"
              id="mp-drawer-city"
              class="mp-delivery-info__input"
              name="attributes[Delivery city]"
              autocomplete="address-level2"
              placeholder="Варна"
              required
            >
          </div>
          <div class="mp-delivery-info__col mp-delivery-info__col--zip">
            <label class="mp-delivery-info__label" for="mp-drawer-zip">Пощенски код *</label>
            <input
              type="text"
              id="mp-drawer-zip"
              class="mp-delivery-info__input"
              name="attributes[Delivery zip]"
              inputmode="numeric"
              autocomplete="postal-code"
              pattern="^[0-9]{4}$"
              maxlength="4"
              placeholder="9000"
              required
            >
          </div>
        </div>

        <small class="mp-delivery-info__hint">Необходимо за доставка с Wolt — куриерът ще бъде изпратен до този адрес</small>
        <div class="mp-delivery-info__error" id="mp-drawer-address-error" role="alert" aria-live="polite"></div>
      </div>
    </div>
    <a
      href="/checkout"
      class="mp-drawer__cta"
      id="mp-drawer-cta"
      style="--mp-cta-bg: {{ cart_cta_color | default: '#024b40' }};"
    >
      {{ cart_cta_text | default: 'Завърши поръчката' }}
    </a>
  </div>
</div>

{%- comment -%} ═══ Mobile bottom badge + sheet ═══ {%- endcomment -%}
<div class="mp-mob-badge" id="mp-mob-badge" style="--mp-badge-bg: {{ cart_badge_bg | default: '#024b40' }};">
  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
    <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4zM3 6h18"/>
    <path d="M16 10a4 4 0 01-8 0"/>
  </svg>
  <span class="mp-mob-badge__count" id="mp-cart-count-mobile" data-count="0">0</span>
  <svg class="mp-mob-badge__arrow" width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M7 11V3M3 7l4-4 4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
</div>

